---
interface Props {
  title: string;
  description: string;
  icon?: string;
}

const { title, description, icon = '🔧' } = Astro.props;
---

<div class="tool-page">
  <div class="tool-header">
    <span class="tool-icon">{icon}</span>
    <div>
      <h1>{title}</h1>
      <p>{description}</p>
    </div>
  </div>
  
  <div class="tool-content">
    <slot />
  </div>
</div>

<style>
  .tool-page {
    max-width: 900px;
    margin: 2rem auto;
    padding: 0 1.5rem;
  }
  
  .tool-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-color);
  }
  
  .tool-icon {
    font-size: 2.5rem;
  }
  
  .tool-header h1 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }
  
  .tool-header p {
    color: var(--text-secondary);
  }
  
  .tool-content {
    background: var(--bg-secondary);
    border-radius: var(--radius);
    padding: 2rem;
    border: 1px solid var(--border-color);
  }
</style>
