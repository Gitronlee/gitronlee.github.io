---
import SearchOverlay from './SearchOverlay.astro';

const path = Astro.url.pathname;
const navItems = [
  { label: '首页', href: '/' },
  { label: '工具', href: '/tools' },
  { label: '游戏', href: '/games' },
  { label: '文档', href: '/docs' },
];
---

<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <span class="logo-icon">🧰</span>
      <span class="logo-text">Web Toolbox</span>
    </a>
    
    <nav class="nav-desktop">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={['nav-link', { active: path.startsWith(item.href) && (item.href === '/' ? path === '/' : true) }]}
        >
          {item.label}
        </a>
      ))}
      
      <button class="search-trigger" id="searchTrigger" type="button">
        <span class="search-trigger-icon">🔍</span>
        <span class="search-trigger-text">搜索...</span>
        <span class="search-trigger-kbd"><kbd>Ctrl</kbd><kbd>K</kbd></span>
      </button>
    </nav>
    
    <button class="menu-toggle" id="menuToggle" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
  
  <nav class="nav-mobile" id="navMobile">
    {navItems.map((item) => (
      <a
        href={item.href}
        class:list={['nav-link', { active: path.startsWith(item.href) && (item.href === '/' ? path === '/' : true) }]}
      >
        {item.label}
      </a>
    ))}
  </nav>
  
  <SearchOverlay />
</header>

<script>
  const menuToggle = document.getElementById('menuToggle');
  const navMobile = document.getElementById('navMobile');
  const searchTrigger = document.getElementById('searchTrigger');
  const searchOverlay = document.getElementById('searchOverlay');
  
  menuToggle?.addEventListener('click', () => {
    navMobile?.classList.toggle('open');
    menuToggle.classList.toggle('open');
  });

  function openSearch() {
    if (searchOverlay) {
      searchOverlay.classList.remove('hidden');
      searchOverlay.classList.add('visible');
      const input = document.getElementById('searchInput');
      if (input) setTimeout(() => input.focus(), 100);
    }
  }

  searchTrigger?.addEventListener('click', openSearch);

  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
    }
  });
</script>

<style>
  .header {
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-color);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }
  
  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  
  .logo-icon {
    font-size: 1.5rem;
  }
  
  .nav-desktop {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  
  .nav-link {
    color: var(--text-secondary);
    font-weight: 500;
    padding: 0.5rem 0;
    position: relative;
  }
  
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--accent-blue);
    transition: width 0.2s;
  }
  
  .nav-link:hover,
  .nav-link.active {
    color: var(--text-primary);
  }
  
  .nav-link.active::after {
    width: 100%;
  }

  .search-trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 0.4rem 0.75rem;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 0.875rem;
    transition: var(--transition);
  }

  .search-trigger:hover {
    border-color: var(--accent-blue);
    color: var(--text-primary);
  }

  .search-trigger-icon {
    font-size: 1rem;
  }

  .search-trigger-text {
    min-width: 60px;
    text-align: left;
  }

  .search-trigger-kbd {
    display: flex;
    gap: 2px;
    margin-left: 0.5rem;
  }

  .search-trigger-kbd kbd {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 0.1rem 0.35rem;
    font-size: 0.7rem;
    font-family: inherit;
    color: var(--text-muted);
  }
  
  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }
  
  .menu-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--text-primary);
    transition: var(--transition);
  }
  
  .nav-mobile {
    display: none;
    flex-direction: column;
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    padding: 1rem 0;
  }
  
  .nav-mobile.open {
    display: flex;
  }
  
  .nav-mobile .nav-link {
    padding: 0.75rem 1.5rem;
  }
  
  @media (max-width: 768px) {
    .nav-desktop {
      display: none;
    }
    
    .menu-toggle {
      display: flex;
    }
    
    .menu-toggle.open span:nth-child(1) {
      transform: rotate(45deg) translate(5px, 5px);
    }
    
    .menu-toggle.open span:nth-child(2) {
      opacity: 0;
    }
    
    .menu-toggle.open span:nth-child(3) {
      transform: rotate(-45deg) translate(5px, -5px);
    }
  }
</style>
