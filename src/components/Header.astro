---
import SearchOverlay from './SearchOverlay.astro';

const path = Astro.url.pathname;
const navItems = [
  { label: '首页', href: '/' },
  { label: '工具', href: '/tools' },
  { label: '游戏', href: '/games' },
  { label: '文档', href: '/docs' },
];
---

<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <span class="logo-icon">🧰</span>
      <span class="logo-text">Tooli</span>
    </a>
    
    <nav class="nav-desktop">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={['nav-link', { active: path.startsWith(item.href) && (item.href === '/' ? path === '/' : true) }]}
        >
          {item.label}
        </a>
      ))}
      
      <a
        href="https://github.com/Gitronlee/gitronlee.github.io"
        class="github-link"
        target="_blank"
        rel="noopener noreferrer"
        title="Star / Fork on GitHub"
      >
        <svg class="github-icon" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        <span class="github-label">GitHub</span>
      </a>
      
      <button class="theme-toggle" id="themeToggle" type="button" aria-label="切换主题" title="切换主题">
        <svg class="theme-icon theme-icon-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="theme-icon theme-icon-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
      
      <button class="search-trigger" id="searchTrigger" type="button">
        <span class="search-trigger-icon">🔍</span>
        <span class="search-trigger-text">搜索...</span>
        <span class="search-trigger-kbd"><kbd>Ctrl</kbd><kbd>K</kbd></span>
      </button>
    </nav>
    
    <button class="menu-toggle" id="menuToggle" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
  
  <nav class="nav-mobile" id="navMobile">
    {navItems.map((item) => (
      <a
        href={item.href}
        class:list={['nav-link', { active: path.startsWith(item.href) && (item.href === '/' ? path === '/' : true) }]}
      >
        {item.label}
      </a>
    ))}
  </nav>
  
  <SearchOverlay />
</header>

<script>
  const menuToggle = document.getElementById('menuToggle');
  const navMobile = document.getElementById('navMobile');
  const searchTrigger = document.getElementById('searchTrigger');
  const searchOverlay = document.getElementById('searchOverlay');
  const themeToggle = document.getElementById('themeToggle');

  function getTheme() {
    try { return localStorage.getItem('theme') || 'light'; } catch { return 'light'; }
  }

  function setTheme(theme: string) {
    document.documentElement.setAttribute('data-theme', theme);
    try { localStorage.setItem('theme', theme); } catch {}
  }

  // Apply saved theme immediately
  setTheme(getTheme());

  themeToggle?.addEventListener('click', () => {
    const next = getTheme() === 'dark' ? 'light' : 'dark';
    setTheme(next);
  });
  
  menuToggle?.addEventListener('click', () => {
    navMobile?.classList.toggle('open');
    menuToggle.classList.toggle('open');
  });

  function openSearch() {
    if (searchOverlay) {
      searchOverlay.classList.remove('hidden');
      searchOverlay.classList.add('visible');
      const input = document.getElementById('searchInput');
      if (input) setTimeout(() => input.focus(), 100);
    }
  }

  searchTrigger?.addEventListener('click', openSearch);

  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
    }
  });
</script>

<style>
  .header {
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-color);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }
  
  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  
  .logo-icon {
    font-size: 1.5rem;
  }
  
  .nav-desktop {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  
  .nav-link {
    color: var(--text-secondary);
    font-weight: 500;
    padding: 0.5rem 0;
    position: relative;
  }
  
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--accent-blue);
    transition: width 0.2s;
  }
  
  .nav-link:hover,
  .nav-link.active {
    color: var(--text-primary);
  }
  
  .nav-link.active::after {
    width: 100%;
  }

  .search-trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 0.4rem 0.75rem;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 0.875rem;
    transition: var(--transition);
  }

  .search-trigger:hover {
    border-color: var(--accent-blue);
    color: var(--text-primary);
  }

  .github-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-secondary);
    font-weight: 500;
    transition: var(--transition);
  }

  .github-link:hover {
    color: var(--text-primary);
  }

  .github-icon {
    width: 1.25rem;
    height: 1.25rem;
  }

  .github-label {
    font-size: 0.9375rem;
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.3rem;
    border-radius: 8px;
    color: var(--text-secondary);
    transition: var(--transition);
  }

  .theme-toggle:hover {
    color: var(--accent-orange);
    background: var(--bg-primary);
  }

  .theme-icon {
    width: 1.25rem;
    height: 1.25rem;
    transition: var(--transition);
  }

  [data-theme="dark"] .theme-icon-light { display: block; }
  [data-theme="dark"] .theme-icon-dark  { display: none; }
  [data-theme="light"] .theme-icon-light { display: none; }
  [data-theme="light"] .theme-icon-dark  { display: block; }

  .search-trigger-icon {
    font-size: 1rem;
  }

  .search-trigger-text {
    min-width: 60px;
    text-align: left;
  }

  .search-trigger-kbd {
    display: flex;
    gap: 2px;
    margin-left: 0.5rem;
  }

  .search-trigger-kbd kbd {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 0.1rem 0.35rem;
    font-size: 0.7rem;
    font-family: inherit;
    color: var(--text-muted);
  }
  
  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }
  
  .menu-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--text-primary);
    transition: var(--transition);
  }
  
  .nav-mobile {
    display: none;
    flex-direction: column;
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    padding: 1rem 0;
  }
  
  .nav-mobile.open {
    display: flex;
  }
  
  .nav-mobile .nav-link {
    padding: 0.75rem 1.5rem;
  }
  
  @media (max-width: 768px) {
    .nav-desktop {
      display: none;
    }
    
    .menu-toggle {
      display: flex;
    }
    
    .menu-toggle.open span:nth-child(1) {
      transform: rotate(45deg) translate(5px, 5px);
    }
    
    .menu-toggle.open span:nth-child(2) {
      opacity: 0;
    }
    
    .menu-toggle.open span:nth-child(3) {
      transform: rotate(-45deg) translate(5px, -5px);
    }

    .github-label {
      display: none;
    }
  }
</style>
