<div class="wt-wrapper">
  <div class="wt-main">
    <div class="wt-grid" id="wtGrid"></div>
    <div class="wt-buttons" id="wtButtons"></div>
  </div>
  <div class="wt-sidebar">
    <div class="wt-stat">
      <span class="wt-stat-label">得分</span>
      <span class="wt-stat-value" id="wtScore">0</span>
    </div>
    <div class="wt-stat">
      <span class="wt-stat-label">速度等级</span>
      <span class="wt-stat-value" id="wtLevel">1</span>
    </div>
    <div class="wt-stat">
      <span class="wt-stat-label">间隔</span>
      <span class="wt-stat-value" id="wtInterval">1.2s</span>
    </div>
    <div class="wt-next-preview">
      <span class="wt-stat-label">下一个</span>
      <div class="wt-next-word" id="wtNextWord">--</div>
    </div>
    <button class="wt-restart" id="wtRestart">重新开始</button>
  </div>
</div>

<div class="wt-overlay hidden" id="wtOverlay">
  <div class="wt-overlay-box">
    <h2>Game Over</h2>
    <p class="wt-final-score">最终得分: <span id="wtFinalScore">0</span></p>
    <button class="wt-restart-btn" id="wtOverlayRestart">再来一局</button>
  </div>
</div>

<script>
  const COLS = 8;
  const ROWS = 10;
  const START_SPEED = 1200;
  const MIN_SPEED = 400;
  const SPEED_STEP = 100;

  const VOCAB: [string, string][] = [
    ['apple','苹果'],['book','书本'],['cat','猫'],['dog','狗'],
    ['fish','鱼'],['bird','鸟'],['tree','树'],['star','星星'],
    ['moon','月亮'],['sun','太阳'],['cloud','云朵'],['rain','雨'],
    ['snow','雪'],['wind','风'],['fire','火'],['water','水'],
    ['house','房子'],['school','学校'],['teacher','老师'],['student','学生'],
    ['happy','快乐'],['big','大'],['small','小'],['hot','热'],['cold','冷'],
  ];

  type Cell = { en: string; cn: string; fixed?: boolean } | null;

  const grid: Cell[][] = [];
  let falling: { col: number; row: number; en: string; cn: string } | null = null;
  let nextEn = '';
  let nextCn = '';
  let score = 0;
  let speed = START_SPEED;
  let timer: ReturnType<typeof setInterval> | null = null;
  let gameOver = false;
  let animating = false;

  // --- Init grid ---
  function initGrid() {
    for (let r = 0; r < ROWS; r++) {
      grid[r] = [];
      for (let c = 0; c < COLS; c++) {
        grid[r][c] = null;
      }
    }
    // Pre-seed 1-2 bottom rows with random letter blocks
    const seedRows = 1 + Math.floor(Math.random() * 2);
    const letters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    for (let r = ROWS - seedRows; r < ROWS; r++) {
      for (let c = 0; c < COLS; c++) {
        const li = Math.floor(Math.random() * letters.length);
        grid[r][c] = { en: letters[li], cn: '', fixed: true };
      }
    }
  }

  function pickWord() {
    const i = Math.floor(Math.random() * VOCAB.length);
    return { en: VOCAB[i][0], cn: VOCAB[i][1] };
  }

  function getDistractors(correctCn: string): string[] {
    const pool = VOCAB.filter(([, cn]) => cn !== correctCn).map(([, cn]) => cn);
    shuffle(pool);
    return pool.slice(0, 3);
  }

  function shuffle<T>(arr: T[]) {
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [arr[i], arr[j]] = [arr[j], arr[i]];
    }
  }

  // --- Spawn ---
  function spawnFalling() {
    const en = nextEn;
    const cn = nextCn;
    nextEn = pickWord().en;
    nextCn = pickWord().cn;

    const col = Math.floor(Math.random() * COLS);
    // Check if top row is occupied at that column
    if (grid[0][col] !== null) {
      endGame();
      return;
    }
    falling = { col, row: 0, en, cn };
    updateNextPreview();
  }

  function updateNextPreview() {
    const el = document.getElementById('wtNextWord');
    if (el) el.textContent = nextEn;
  }

  // --- Game logic ---
  function canMoveDown(): boolean {
    if (!falling) return false;
    const nextRow = falling.row + 1;
    if (nextRow >= ROWS) return false;
    return grid[nextRow][falling.col] === null;
  }

  function fixFalling() {
    if (!falling) return;
    grid[falling.row][falling.col] = { en: falling.en, cn: falling.cn, fixed: true };
    falling = null;
    checkElimination();
    checkGameOver();
    if (!gameOver) spawnFalling();
  }

  function checkElimination() {
    const fullRows: number[] = [];
    for (let r = ROWS - 1; r >= 0; r--) {
      if (grid[r].every((cell) => cell !== null)) {
        fullRows.push(r);
      }
    }
    if (fullRows.length === 0) return;

    // Flash animation
    const cells = document.querySelectorAll('.wt-cell');
    for (const r of fullRows) {
      for (let c = 0; c < COLS; c++) {
        const idx = r * COLS + c;
        cells[idx]?.classList.add('flash');
      }
    }

    // Wait for flash, then eliminate
    if (timer) clearInterval(timer);
    setTimeout(() => {
      fullRows.sort((a, b) => b - a);
      for (const r of fullRows) {
        grid.splice(r, 1);
        grid.unshift(new Array(COLS).fill(null));
        score += 20;
      }
      updateScore();
      if (!falling && !gameOver) spawnFalling();
      render();
      buildButtons();
      startTimer();
    }, 300);
  }

  function checkGameOver() {
    if (grid[0].some((cell) => cell !== null)) {
      endGame();
    }
  }

  function endGame() {
    gameOver = true;
    if (timer) { clearInterval(timer); timer = null; }
    document.getElementById('wtFinalScore')!.textContent = String(score);
    document.getElementById('wtOverlay')!.classList.remove('hidden');
  }

  function updateScore() {
    document.getElementById('wtScore')!.textContent = String(score);
    const oldSpeed = speed;
    const level = Math.floor(score / 50) + 1;
    speed = Math.max(MIN_SPEED, START_SPEED - (level - 1) * SPEED_STEP);
    document.getElementById('wtLevel')!.textContent = String(level);
    document.getElementById('wtInterval')!.textContent = (speed / 1000).toFixed(1) + 's';
    if (oldSpeed !== speed && !gameOver && timer) {
      clearInterval(timer);
      timer = setInterval(tick, speed);
    }
  }

  // --- Render ---
  function render() {
    const gridEl = document.getElementById('wtGrid')!;
    let html = '';
    for (let r = 0; r < ROWS; r++) {
      for (let c = 0; c < COLS; c++) {
        const cell = grid[r][c];
        let cls = 'wt-cell';
        let text = '';
        if (cell) {
          cls += ' wt-filled';
          if (cell.cn === '') cls += ' wt-seed';
          text = cell.en;
        }
        if (falling && falling.row === r && falling.col === c) {
          cls += ' wt-falling';
          text = falling.en;
        }
        html += `<div class="${cls}">${text}</div>`;
      }
    }
    gridEl.innerHTML = html;
  }

  function renderButtons() {
    if (!falling) return;
    const correctCn = falling.cn;
    const distractors = getDistractors(correctCn);
    const options = [correctCn, ...distractors];
    shuffle(options);

    const container = document.getElementById('wtButtons')!;
    container.innerHTML = options.map((cn, i) => {
      const correct = cn === correctCn;
      return `<button class="wt-btn" data-correct="${correct}" data-cn="${cn}" data-idx="${i}">${cn}</button>`;
    }).join('');

    // Bind click handlers
    container.querySelectorAll('.wt-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        if (gameOver || animating || !falling) return;
        const correct = btn.getAttribute('data-correct') === 'true';
        if (correct) {
          handleCorrect();
        } else {
          handleWrong(btn as HTMLElement);
        }
      });
    });
  }

  function handleCorrect() {
    if (!falling) return;
    falling = null;
    score += 10;
    updateScore();
    animateDestroy();
    render();
    buildButtons();
  }

  function handleWrong(btn: HTMLElement) {
    if (!falling) return;
    score = Math.max(0, score - 2);
    updateScore();
    animating = true;
    // Flash red on the falling cell
    const fallingCell = document.querySelector('.wt-falling') as HTMLElement;
    if (fallingCell) {
      fallingCell.classList.add('wt-wrong');
      setTimeout(() => {
        fallingCell.classList.remove('wt-wrong');
        animating = false;
      }, 400);
    }
    // Flash the button
    btn.classList.add('wt-btn-wrong');
    setTimeout(() => btn.classList.remove('wt-btn-wrong'), 400);
  }

  function animateDestroy() {
    const fallingCell = document.querySelector('.wt-falling') as HTMLElement;
    if (fallingCell) {
      fallingCell.classList.add('wt-destroy');
    }
  }

  function buildButtons() {
    if (falling) renderButtons();
    else {
      const container = document.getElementById('wtButtons')!;
      container.innerHTML = '';
    }
  }

  // --- Game loop ---
  function tick() {
    if (gameOver) return;
    if (!falling) return;

    if (canMoveDown()) {
      falling.row++;
      render();
      buildButtons();
    } else {
      // Cannot move - fix the block
      // Only fix if it has fallen at least past row 0
      fixFalling();
      render();
      buildButtons();
    }
  }

  function startTimer() {
    if (timer) clearInterval(timer);
    timer = setInterval(tick, speed);
  }

  // --- Restart ---
  function restart() {
    if (timer) { clearInterval(timer); timer = null; }
    gameOver = false;
    animating = false;
    score = 0;
    speed = START_SPEED;
    falling = null;
    initGrid();
    nextEn = pickWord().en;
    nextCn = pickWord().cn;
    updateScore();
    updateNextPreview();
    render();
    document.getElementById('wtOverlay')!.classList.add('hidden');
    spawnFalling();
    render();
    buildButtons();
    startTimer();
  }

  // --- Touch / mobile ---
  document.getElementById('wtRestart')!.addEventListener('click', restart);
  document.getElementById('wtOverlayRestart')!.addEventListener('click', restart);

  // --- Start ---
  initGrid();
  nextEn = pickWord().en;
  nextCn = pickWord().cn;
  updateScore();
  updateNextPreview();
  render();
  // Wait a moment then spawn first word
  setTimeout(() => {
    spawnFalling();
    render();
    buildButtons();
    startTimer();
  }, 500);
</script>

<style>
