---
import grade1 from '../../data/word-tetris/grade-1.json';
import grade2 from '../../data/word-tetris/grade-2.json';
import grade3 from '../../data/word-tetris/grade-3.json';
import grade4 from '../../data/word-tetris/grade-4.json';
import grade5 from '../../data/word-tetris/grade-5.json';
import grade6 from '../../data/word-tetris/grade-6.json';
import grade7 from '../../data/word-tetris/grade-7.json';
import grade8 from '../../data/word-tetris/grade-8.json';
import grade9 from '../../data/word-tetris/grade-9.json';

const allGrades: Record<number, { en: string; cn: string }[]> = {
  1: grade1, 2: grade2, 3: grade3, 4: grade4, 5: grade5,
  6: grade6, 7: grade7, 8: grade8, 9: grade9,
};
---

<div id="wtGradeData" data-grades={JSON.stringify(allGrades)} style="display:none"></div>

<div class="wt-wrapper">
  <div class="wt-scorebar">
    <span class="wt-score-item">得分 <strong id="wtScore">0</strong></span>
    <span class="wt-score-divider">|</span>
    <span class="wt-score-item" id="wtLevelLabel">一年级</span>
    <span class="wt-score-divider">|</span>
    <span class="wt-score-item">已消 <strong id="wtCompleted">0</strong> / <strong id="wtTotal">0</strong></span>
  </div>
  <div class="wt-grid" id="wtGrid"></div>
  <div class="wt-controls">
    <button class="wt-btn wt-drop-btn" id="wtDrop">直接下落</button>
    <button class="wt-btn wt-restart" id="wtRestart">重新开始</button>
    <button class="wt-btn wt-study-btn" id="wtStudy">学习复习</button>
    <span class="wt-level-pick">
      起始年级
      <select id="wtDifficulty" class="wt-difficulty-select">
        <optgroup label="小学">
          <option value="1" selected>一年级</option>
          <option value="2">二年级</option>
          <option value="3">三年级</option>
          <option value="4">四年级</option>
          <option value="5">五年级</option>
          <option value="6">六年级</option>
        </optgroup>
        <optgroup label="初中">
          <option value="7">初一</option>
          <option value="8">初二</option>
          <option value="9">初三</option>
        </optgroup>
      </select>
    </span>
  </div>
</div>

<div class="wt-overlay hidden" id="wtOverlay">
  <div class="wt-overlay-box">
    <h2 id="wtOverlayTitle">Game Over</h2>
    <p class="wt-final-score">最终得分: <span id="wtFinalScore">0</span></p>
    <button class="wt-restart-btn" id="wtOverlayRestart">再来一局</button>
  </div>
</div>

<div class="wt-level-flash hidden" id="wtLevelFlash">
  <div class="wt-level-flash-text" id="wtLevelFlashText"></div>
</div>

<div class="wt-study-overlay hidden" id="wtStudyOverlay">
  <div class="wt-study-box">
    <div class="wt-study-header">
      <h2 id="wtStudyTitle">学习复习</h2>
      <button class="wt-study-close" id="wtStudyClose">×</button>
    </div>
    <div class="wt-study-list" id="wtStudyList"></div>
    <div class="wt-study-footer">
      <button class="wt-btn wt-study-start-btn" id="wtStudyStart">开始游戏</button>
    </div>
  </div>
</div>

<script>
  const COLS = 8;
  const ROWS = 10;
  const SPEED = 700;

  const GRADE_NAMES = ['','一年级','二年级','三年级','四年级','五年级','六年级','初一','初二','初三'];

  const gradeDataEl = document.getElementById('wtGradeData');
  const ALL_GRADES: Record<number, { en: string; cn: string; phon?: string }[]> = JSON.parse(gradeDataEl!.dataset.grades || '{}');

  type Cell = { en: string; cn: string; phon: string; lang: 'en' | 'cn'; fixed?: boolean } | null;

  const grid: Cell[][] = [];
  let falling: { col: number; row: number; en: string; cn: string; phon: string; lang: 'en' | 'cn' } | null = null;
  let nextEn = '';
  let nextCn = '';
  let nextPhon = '';
  let nextLang: 'en' | 'cn' = 'en';
  let lastCol = -1;
  let score = 0;
  let level = 1;
  let currentGradeWords: { en: string; cn: string; phon?: string }[] = [];
  let eliminatedKeys: Set<string> = new Set();
  let timer: ReturnType<typeof setInterval> | null = null;
  let gameOver = false;
  let animating = false;

  function flipLang(l: 'en' | 'cn'): 'en' | 'cn' {
    return l === 'en' ? 'cn' : 'en';
  }

  function loadGrade(grade: number) {
    currentGradeWords = ALL_GRADES[grade] || [];
  }

  function pickWord(): { en: string; cn: string; phon: string } {
    const pool = currentGradeWords.filter(w => !eliminatedKeys.has(w.en + ':' + w.cn));
    const i = Math.floor(Math.random() * pool.length);
    return { en: pool[i].en, cn: pool[i].cn, phon: pool[i].phon || '' };
  }

  function checkLevelComplete(): boolean {
    return currentGradeWords.filter(w => !eliminatedKeys.has(w.en + ':' + w.cn)).length === 0;
  }

  function updateLevelLabel() {
    document.getElementById('wtLevelLabel')!.textContent = GRADE_NAMES[level];
  }

  function showLevelFlash() {
    const el = document.getElementById('wtLevelFlash')!;
    document.getElementById('wtLevelFlashText')!.textContent = GRADE_NAMES[level];
    el.classList.remove('hidden');
    setTimeout(() => el.classList.add('hidden'), 1500);
  }

  function advanceLevel() {
    level++;
    if (level > 9) {
      document.getElementById('wtOverlayTitle')!.textContent = '全部通关!';
      endGame();
      return;
    }
    if (timer) { clearInterval(timer); timer = null; }
    loadGrade(level);
    showLevelFlash();
    updateLevelLabel();
    falling = null;
    lastCol = -1;
    initGrid();
    updateScore();
    updateWordCount();
    render();
    const w = pickWord();
    nextEn = w.en;
    nextCn = w.cn;
    nextPhon = w.phon;
    nextLang = Math.random() < 0.5 ? 'en' : 'cn';
    setTimeout(() => {
      if (gameOver) return;
      spawnFalling();
      render();
      startTimer();
    }, 1600);
  }

  function pickBestColumn(): number {
    const heights: number[] = [];
    for (let c = 0; c < COLS; c++) {
      let h = 0;
      for (let r = ROWS - 1; r >= 0 && grid[r][c] !== null; r--, h++) {}
      heights.push(h);
    }
    const minH = Math.min(...heights);
    const candidates: number[] = [];
    for (let c = 0; c < COLS; c++) {
      if (heights[c] === minH) candidates.push(c);
    }
    for (const c of candidates) {
      if (c > lastCol) { lastCol = c; return c; }
    }
    lastCol = candidates[0];
    return candidates[0];
  }

  function initGrid() {
    for (let r = 0; r < ROWS; r++) {
      grid[r] = [];
      for (let c = 0; c < COLS; c++) {
        grid[r][c] = null;
      }
    }
  }

  function spawnFalling() {
    const en = nextEn;
    const cn = nextCn;
    const phon = nextPhon;
    const lang = nextLang;

    const nextWordLang = flipLang(lang);
    const p = pickWord();
    nextEn = p.en;
    nextCn = p.cn;
    nextPhon = p.phon;
    nextLang = nextWordLang;

    const col = pickBestColumn();
    if (grid[0][col] !== null) {
      endGame();
      return;
    }
    falling = { col, row: 0, en, cn, phon, lang };
  }

  function canMoveDown(): boolean {
    if (!falling) return false;
    const nextRow = falling.row + 1;
    if (nextRow >= ROWS) return false;
    return grid[nextRow][falling.col] === null;
  }

  function applyGravity(col: number) {
    for (let r = ROWS - 2; r >= 0; r--) {
      if (grid[r][col] !== null && grid[r + 1][col] === null) {
        grid[r + 1][col] = grid[r][col];
        grid[r][col] = null;
      }
    }
  }

  function fixFalling() {
    if (!falling) return;
    grid[falling.row][falling.col] = {
      en: falling.en, cn: falling.cn, phon: falling.phon, lang: falling.lang, fixed: true,
    };
    falling = null;
    if (checkGameOver()) return;
    spawnFalling();
  }

  function checkGameOver(): boolean {
    if (grid[0].some((cell) => cell !== null)) {
      endGame();
      return true;
    }
    return false;
  }

  function endGame() {
    gameOver = true;
    if (timer) { clearInterval(timer); timer = null; }
    document.getElementById('wtOverlayTitle')!.textContent = '挑战失败';
    document.getElementById('wtFinalScore')!.textContent = String(score);
    document.getElementById('wtOverlay')!.classList.remove('hidden');
  }

  function updateScore() {
    document.getElementById('wtScore')!.textContent = String(score);
  }

  function updateWordCount() {
    const total = currentGradeWords.length;
    const completed = currentGradeWords.filter(w => eliminatedKeys.has(w.en + ':' + w.cn)).length;
    document.getElementById('wtCompleted')!.textContent = String(completed);
    document.getElementById('wtTotal')!.textContent = String(total);
  }

  function render() {
    const gridEl = document.getElementById('wtGrid')!;
    let html = '';
    for (let r = 0; r < ROWS; r++) {
      for (let c = 0; c < COLS; c++) {
        const cell = grid[r][c];
        let cls = 'wt-cell';
        let wordText = '';
        let phonText = '';
        if (cell) {
          cls += ' wt-filled';
          if (cell.cn === '') {
            cls += ' wt-seed';
          } else if (cell.lang === 'en') {
            cls += ' wt-en';
            wordText = cell.en;
            phonText = cell.phon || '';
          } else {
            cls += ' wt-cn';
            wordText = cell.cn;
          }
        }
        if (falling && falling.row === r && falling.col === c) {
          cls += ' wt-falling';
          if (falling.lang === 'en') {
            cls += ' wt-falling-en';
            wordText = falling.en;
            phonText = falling.phon || '';
          } else {
            cls += ' wt-falling-cn';
            wordText = falling.cn;
          }
        }
        html += `<div class="${cls}"><span class="wt-word">${wordText}</span>${phonText ? `<span class="wt-phon">${phonText}</span>` : ''}</div>`;
      }
    }
    gridEl.innerHTML = html;

    gridEl.querySelectorAll('.wt-filled:not(.wt-seed):not(.wt-falling)').forEach((el) => {
      el.addEventListener('click', () => {
        if (gameOver || animating || !falling) return;
        const idx = Array.from(gridEl.children).indexOf(el);
        const r = Math.floor(idx / COLS);
        const c = idx % COLS;
        const cell = grid[r][c];
        if (!cell || !cell.fixed) return;
        if (cell.en === falling.en && cell.cn === falling.cn && cell.lang !== falling.lang) {
          handlePairMatch(r, c);
        } else {
          handleGridWrong(el as HTMLElement);
        }
      });
    });
  }

  function handlePairMatch(r: number, c: number) {
    if (!falling) return;
    eliminatedKeys.add(falling.en + ':' + falling.cn);
    grid[r][c] = null;
    falling = null;
    score += 10;
    updateScore();
    updateWordCount();
    animateDestroy();
    render();
    applyGravity(c);
    render();
    if (checkLevelComplete()) {
      advanceLevel();
      return;
    }
    if (!gameOver) spawnFalling();
    render();
  }

  function handleGridWrong(el: HTMLElement) {
    if (!falling) return;
    score = Math.max(0, score - 2);
    updateScore();
    animating = true;
    const fallingCell = document.querySelector('.wt-falling') as HTMLElement;
    if (fallingCell) fallingCell.classList.add('wt-wrong');
    el.classList.add('wt-wrong');
    setTimeout(() => {
      if (fallingCell) fallingCell.classList.remove('wt-wrong');
      el.classList.remove('wt-wrong');
      animating = false;
    }, 400);
  }

  function animateDestroy() {
    const fallingCell = document.querySelector('.wt-falling') as HTMLElement;
    if (fallingCell) fallingCell.classList.add('wt-destroy');
  }

  function tick() {
    if (gameOver) return;
    if (!falling) return;
    if (canMoveDown()) {
      falling.row++;
      render();
    } else {
      fixFalling();
      render();
    }
  }

  function startTimer() {
    if (timer) clearInterval(timer);
    timer = setInterval(tick, SPEED);
  }

  function dropNow() {
    if (gameOver || !falling) return;
    while (canMoveDown()) { falling.row++; }
    fixFalling();
    render();
  }

  function restart() {
    if (timer) { clearInterval(timer); timer = null; }
    level = Number((document.getElementById('wtDifficulty') as HTMLSelectElement).value);
    loadGrade(level);
    eliminatedKeys = new Set();
    gameOver = false;
    animating = false;
    score = 0;
    falling = null;
    lastCol = -1;
    initGrid();
    const w = pickWord();
    nextEn = w.en;
    nextCn = w.cn;
    nextPhon = w.phon;
    nextLang = Math.random() < 0.5 ? 'en' : 'cn';
    updateScore();
    updateWordCount();
    updateLevelLabel();
    render();
    document.getElementById('wtOverlay')!.classList.add('hidden');
    spawnFalling();
    render();
    startTimer();
  }

  document.getElementById('wtDrop')!.addEventListener('click', dropNow);
  document.getElementById('wtRestart')!.addEventListener('click', restart);
  document.getElementById('wtOverlayRestart')!.addEventListener('click', restart);
  document.getElementById('wtDifficulty')!.addEventListener('change', restart);

  function showStudyModal() {
    if (timer) { clearInterval(timer); timer = null; }
    gameOver = true;
    const list = document.getElementById('wtStudyList')!;
    const title = document.getElementById('wtStudyTitle')!;
    title.textContent = `${GRADE_NAMES[level]} - 学习复习`;
    let html = '<div class="wt-study-table"><div class="wt-study-row wt-study-header-row"><div class="wt-study-cell wt-study-en">English</div><div class="wt-study-cell wt-study-phon">Phonetic</div><div class="wt-study-cell wt-study-cn">中文</div></div>';
    currentGradeWords.forEach(w => {
      html += `<div class="wt-study-row"><div class="wt-study-cell wt-study-en">${w.en}</div><div class="wt-study-cell wt-study-phon">${w.phon || ''}</div><div class="wt-study-cell wt-study-cn">${w.cn}</div></div>`;
    });
    html += '</div>';
    list.innerHTML = html;
    document.getElementById('wtStudyOverlay')!.classList.remove('hidden');
  }

  function closeStudyModal() {
    document.getElementById('wtStudyOverlay')!.classList.add('hidden');
  }

  document.getElementById('wtStudy')!.addEventListener('click', showStudyModal);
  document.getElementById('wtStudyClose')!.addEventListener('click', closeStudyModal);
  document.getElementById('wtStudyStart')!.addEventListener('click', () => {
    closeStudyModal();
    restart();
  });

  level = Number((document.getElementById('wtDifficulty') as HTMLSelectElement).value);
  loadGrade(level);
  initGrid();
  const w0 = pickWord();
  nextEn = w0.en;
  nextCn = w0.cn;
  nextPhon = w0.phon;
  nextLang = Math.random() < 0.5 ? 'en' : 'cn';
  updateScore();
  updateWordCount();
  updateLevelLabel();
  render();

  setTimeout(() => {
    spawnFalling();
    render();
    startTimer();
  }, 500);
</script>

<style is:global>
  .wt-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .wt-scorebar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 0.5rem 1.25rem;
  }

  .wt-score-item strong {
    font-family: 'JetBrains Mono', monospace;
    color: var(--accent-cyan);
  }

  .wt-score-divider {
    color: var(--border-color);
  }

  .wt-controls {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-top: 0.5rem;
  }

  .wt-btn {
    padding: 0.6rem 1.5rem;
    border: none;
    border-radius: 10px;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.15s;
  }

  .wt-drop-btn {
    background: var(--accent-cyan);
    color: #fff;
    box-shadow: 0 2px 8px rgba(6, 182, 212, 0.3);
  }

  .wt-drop-btn:hover {
    background: #0891b2;
    transform: translateY(-1px);
  }

  .wt-restart {
    background: var(--accent-orange);
    color: #fff;
    box-shadow: 0 2px 8px rgba(217, 119, 6, 0.3);
  }

  .wt-restart:hover {
    background: #d97706;
    transform: translateY(-1px);
  }

  .wt-level-pick {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .wt-difficulty-select {
    padding: 0.4rem 0.6rem;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background: var(--bg-primary);
    color: var(--text-primary);
    font-size: 0.875rem;
    cursor: pointer;
  }

  .wt-grid {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    grid-template-rows: repeat(10, 1fr);
    gap: 4px;
    width: 760px;
    height: 480px;
    background: var(--bg-tertiary);
    border: 2px solid var(--border-color);
    border-radius: var(--radius);
    padding: 4px;
    box-shadow: var(--shadow);
  }

  .wt-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    font-weight: 700;
    color: transparent;
    transition: background 0.15s, border-color 0.15s;
    overflow: hidden;
    padding: 2px 3px;
    cursor: default;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
    min-width: 0;
    line-height: 1.15;
  }

  .wt-cell .wt-word {
    font-size: 0.75rem;
    font-weight: 700;
    word-break: break-all;
    overflow: hidden;
    max-width: 100%;
    text-align: center;
  }

  .wt-cell .wt-phon {
    font-size: 0.48rem;
    font-weight: 400;
    opacity: 0.8;
    word-break: break-all;
    overflow: hidden;
    max-width: 100%;
    color: inherit;
    text-align: center;
  }

  .wt-cell.wt-filled { color: var(--text-secondary); }

  .wt-cell.wt-filled.wt-en {
    background: var(--accent-pink);
    border-color: var(--accent-pink);
    color: #fff;
    cursor: pointer;
  }

  .wt-cell.wt-filled.wt-cn {
    background: var(--accent-blue);
    border-color: var(--accent-blue);
    color: #fff;
    cursor: pointer;
  }

  .wt-cell.wt-filled.wt-seed {
    background: var(--bg-tertiary);
    border-color: var(--border-color);
    color: var(--text-muted);
    cursor: default;
  }

  .wt-cell.wt-falling {
    font-weight: 800;
    animation: wtPulse 0.7s ease-in-out infinite;
    cursor: default;
  }

  .wt-cell.wt-falling .wt-word {
    font-size: 0.78rem;
  }

  .wt-cell.wt-falling.wt-falling-en {
    background: var(--accent-pink);
    border-color: var(--accent-pink);
    color: #fff;
    box-shadow: 0 0 18px rgba(236, 72, 153, 0.6), 0 0 40px rgba(236, 72, 153, 0.2);
  }

  .wt-cell.wt-falling.wt-falling-cn {
    background: var(--accent-blue);
    border-color: var(--accent-blue);
    color: #fff;
    box-shadow: 0 0 18px rgba(59, 130, 246, 0.6), 0 0 40px rgba(59, 130, 246, 0.2);
  }

  @keyframes wtPulse {
    0%, 100% { opacity: 0.85; }
    50% { opacity: 1; }
  }

  .wt-cell.wt-wrong {
    background: #dc2626 !important;
    border-color: #fca5a5 !important;
    color: #fff !important;
    animation: none !important;
  }

  .wt-cell.wt-destroy {
    animation: wtDestroy 0.25s ease-out forwards;
  }

  @keyframes wtDestroy {
    0% { transform: scale(1); opacity: 1; background: #22c55e; }
    100% { transform: scale(0.2); opacity: 0; }
  }

  .wt-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 200;
    backdrop-filter: blur(4px);
  }

  .wt-overlay.hidden { display: none; }

  .wt-overlay-box {
    text-align: center;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 2.5rem 3rem;
    box-shadow: 0 0 40px rgba(139, 92, 246, 0.3);
  }

  .wt-overlay-box h2 {
    font-size: 2rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent-purple), var(--accent-pink));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
  }

  .wt-final-score {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  .wt-final-score span {
    color: var(--accent-cyan);
    font-weight: 700;
    font-size: 1.5rem;
  }

  .wt-restart-btn {
    padding: 0.8rem 2rem;
    border: none;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--accent-purple), var(--accent-pink));
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.15s;
    box-shadow: 0 4px 15px rgba(139, 92, 246, 0.3);
  }

  .wt-restart-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(139, 92, 246, 0.5);
  }

  .wt-level-flash {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.8);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 300;
    animation: wtFlashIn 0.35s ease-out;
  }

  .wt-level-flash.hidden { display: none; }

  .wt-level-flash-text {
    font-size: 2rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent-cyan), var(--accent-purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: wtFlashText 0.35s ease-out;
  }

  @keyframes wtFlashIn {
    0% { opacity: 0; }
    100% { opacity: 1; }
  }

  @keyframes wtFlashText {
    0% { transform: scale(0.5); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

