<div class="wt-wrapper">
  <div class="wt-scorebar">
    <span class="wt-score-item">得分 <strong id="wtScore">0</strong></span>
    <span class="wt-score-divider">|</span>
    <span class="wt-score-item">
      难度
      <select id="wtDifficulty" class="wt-difficulty-select">
        <option value="1">初级</option>
        <option value="2">中级</option>
        <option value="3" selected>高级</option>
      </select>
    </span>
  </div>
  <div class="wt-grid" id="wtGrid"></div>
  <button class="wt-restart" id="wtRestart">重新开始</button>
</div>

<div class="wt-overlay hidden" id="wtOverlay">
  <div class="wt-overlay-box">
    <h2>Game Over</h2>
    <p class="wt-final-score">最终得分: <span id="wtFinalScore">0</span></p>
    <button class="wt-restart-btn" id="wtOverlayRestart">再来一局</button>
  </div>
</div>

<script>
  const COLS = 8;
  const ROWS = 10;
  const SPEED = 700;

  const VOCAB: { en: string; cn: string; tier: number }[] = [
    { en: 'apple', cn: '苹果', tier: 1 },
    { en: 'book', cn: '书本', tier: 1 },
    { en: 'cat', cn: '猫', tier: 1 },
    { en: 'dog', cn: '狗', tier: 1 },
    { en: 'fish', cn: '鱼', tier: 1 },
    { en: 'bird', cn: '鸟', tier: 1 },
    { en: 'tree', cn: '树', tier: 1 },
    { en: 'star', cn: '星星', tier: 1 },
    { en: 'moon', cn: '月亮', tier: 1 },
    { en: 'sun', cn: '太阳', tier: 1 },
    { en: 'cloud', cn: '云朵', tier: 1 },
    { en: 'rain', cn: '雨', tier: 1 },
    { en: 'snow', cn: '雪', tier: 2 },
    { en: 'wind', cn: '风', tier: 2 },
    { en: 'fire', cn: '火', tier: 2 },
    { en: 'water', cn: '水', tier: 2 },
    { en: 'house', cn: '房子', tier: 2 },
    { en: 'school', cn: '学校', tier: 2 },
    { en: 'teacher', cn: '老师', tier: 3 },
    { en: 'student', cn: '学生', tier: 3 },
    { en: 'happy', cn: '快乐', tier: 3 },
    { en: 'beautiful', cn: '美丽的', tier: 3 },
    { en: 'flower', cn: '花', tier: 3 },
    { en: 'mountain', cn: '山', tier: 3 },
    { en: 'computer', cn: '电脑', tier: 3 },
  ];

  type Cell = { en: string; cn: string; lang: 'en' | 'cn'; fixed?: boolean } | null;

  const grid: Cell[][] = [];
  let falling: { col: number; row: number; en: string; cn: string; lang: 'en' | 'cn' } | null = null;
  let nextEn = '';
  let nextCn = '';
  let nextLang: 'en' | 'cn' = 'en';
  let lastCol = -1;
  let score = 0;
  let tier = 1;
  let timer: ReturnType<typeof setInterval> | null = null;
  let gameOver = false;
  let animating = false;

  function flipLang(l: 'en' | 'cn'): 'en' | 'cn' {
    return l === 'en' ? 'cn' : 'en';
  }

  function pickWord(): { en: string; cn: string } {
    const pool = VOCAB.filter(w => w.tier <= tier);
    const i = Math.floor(Math.random() * pool.length);
    return { en: pool[i].en, cn: pool[i].cn };
  }

  function pickBestColumn(): number {
    const heights: number[] = [];
    for (let c = 0; c < COLS; c++) {
      let h = 0;
      for (let r = ROWS - 1; r >= 0 && grid[r][c] !== null; r--, h++) {}
      heights.push(h);
    }
    const minH = Math.min(...heights);
    const candidates: number[] = [];
    for (let c = 0; c < COLS; c++) {
      if (heights[c] === minH) candidates.push(c);
    }
    for (const c of candidates) {
      if (c > lastCol) { lastCol = c; return c; }
    }
    lastCol = candidates[0];
    return candidates[0];
  }

  function initGrid() {
    for (let r = 0; r < ROWS; r++) {
      grid[r] = [];
      for (let c = 0; c < COLS; c++) {
        grid[r][c] = null;
      }
    }
    const seedRows = 1 + Math.floor(Math.random() * 2);
    const letters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    for (let r = ROWS - seedRows; r < ROWS; r++) {
      for (let c = 0; c < COLS; c++) {
        const li = Math.floor(Math.random() * letters.length);
        grid[r][c] = { en: letters[li], cn: '', lang: 'en', fixed: true };
      }
    }
  }

  function spawnFalling() {
    const en = nextEn;
    const cn = nextCn;
    const lang = nextLang;

    const nextWordLang = flipLang(lang);
    const p = pickWord();
    nextEn = p.en;
    nextCn = p.cn;
    nextLang = nextWordLang;

    const col = pickBestColumn();
    if (grid[0][col] !== null) {
      endGame();
      return;
    }
    falling = { col, row: 0, en, cn, lang };
  }

  function canMoveDown(): boolean {
    if (!falling) return false;
    const nextRow = falling.row + 1;
    if (nextRow >= ROWS) return false;
    return grid[nextRow][falling.col] === null;
  }

  function applyGravity(col: number) {
    for (let r = ROWS - 2; r >= 0; r--) {
      if (grid[r][col] !== null && grid[r + 1][col] === null) {
        grid[r + 1][col] = grid[r][col];
        grid[r][col] = null;
      }
    }
  }

  function fixFalling() {
    if (!falling) return;
    grid[falling.row][falling.col] = {
      en: falling.en, cn: falling.cn, lang: falling.lang, fixed: true,
    };
    falling = null;
    if (checkGameOver()) return;
    spawnFalling();
  }

  function checkGameOver(): boolean {
    if (grid[0].some((cell) => cell !== null)) {
      endGame();
      return true;
    }
    return false;
  }

  function endGame() {
    gameOver = true;
    if (timer) { clearInterval(timer); timer = null; }
    document.getElementById('wtFinalScore')!.textContent = String(score);
    document.getElementById('wtOverlay')!.classList.remove('hidden');
  }

  function updateScore() {
    document.getElementById('wtScore')!.textContent = String(score);
  }

  function render() {
    const gridEl = document.getElementById('wtGrid')!;
    let html = '';
    for (let r = 0; r < ROWS; r++) {
      for (let c = 0; c < COLS; c++) {
        const cell = grid[r][c];
        let cls = 'wt-cell';
        let text = '';
        if (cell) {
          cls += ' wt-filled';
          if (cell.cn === '') {
            cls += ' wt-seed';
          } else if (cell.lang === 'en') {
            cls += ' wt-en';
          } else {
            cls += ' wt-cn';
          }
          text = cell.lang === 'en' ? cell.en : cell.cn;
        }
        if (falling && falling.row === r && falling.col === c) {
          cls += ' wt-falling';
          if (falling.lang === 'en') cls += ' wt-falling-en';
          else cls += ' wt-falling-cn';
          text = falling.lang === 'en' ? falling.en : falling.cn;
        }
        html += `<div class="${cls}">${text}</div>`;
      }
    }
    gridEl.innerHTML = html;

    gridEl.querySelectorAll('.wt-filled:not(.wt-seed):not(.wt-falling)').forEach((el) => {
      el.addEventListener('click', () => {
        if (gameOver || animating || !falling) return;
        const idx = Array.from(gridEl.children).indexOf(el);
        const r = Math.floor(idx / COLS);
        const c = idx % COLS;
        const cell = grid[r][c];
        if (!cell || !cell.fixed) return;
        if (cell.en === falling.en && cell.cn === falling.cn) {
          handlePairMatch(r, c);
        } else {
          handleGridWrong(el as HTMLElement);
        }
      });
    });
  }

  function handlePairMatch(r: number, c: number) {
    if (!falling) return;
    grid[r][c] = null;
    falling = null;
    score += 10;
    updateScore();
    animateDestroy();
    render();
    applyGravity(c);
    render();
    if (!gameOver) spawnFalling();
    render();
  }

  function handleGridWrong(el: HTMLElement) {
    if (!falling) return;
    score = Math.max(0, score - 2);
    updateScore();
    animating = true;
    const fallingCell = document.querySelector('.wt-falling') as HTMLElement;
    if (fallingCell) fallingCell.classList.add('wt-wrong');
    el.classList.add('wt-wrong');
    setTimeout(() => {
      if (fallingCell) fallingCell.classList.remove('wt-wrong');
      el.classList.remove('wt-wrong');
      animating = false;
    }, 400);
  }

  function animateDestroy() {
    const fallingCell = document.querySelector('.wt-falling') as HTMLElement;
    if (fallingCell) fallingCell.classList.add('wt-destroy');
  }

  function tick() {
    if (gameOver) return;
    if (!falling) return;
    if (canMoveDown()) {
      falling.row++;
      render();
    } else {
      fixFalling();
      render();
    }
  }

  function startTimer() {
    if (timer) clearInterval(timer);
    timer = setInterval(tick, SPEED);
  }

  function restart() {
    if (timer) { clearInterval(timer); timer = null; }
    tier = Number((document.getElementById('wtDifficulty') as HTMLSelectElement).value);
    gameOver = false;
    animating = false;
    score = 0;
    falling = null;
    lastCol = -1;
  tier = Number((document.getElementById('wtDifficulty') as HTMLSelectElement).value);
  initGrid();
    nextEn = pickWord().en;
    nextCn = pickWord().cn;
    nextLang = Math.random() < 0.5 ? 'en' : 'cn';
    updateScore();
    render();
    document.getElementById('wtOverlay')!.classList.add('hidden');
    spawnFalling();
    render();
    startTimer();
  }

  document.getElementById('wtRestart')!.addEventListener('click', restart);
  document.getElementById('wtOverlayRestart')!.addEventListener('click', restart);
  document.getElementById('wtDifficulty')!.addEventListener('change', restart);

  initGrid();
  nextEn = pickWord().en;
  nextCn = pickWord().cn;
  nextLang = Math.random() < 0.5 ? 'en' : 'cn';
  updateScore();
  render();

  setTimeout(() => {
    spawnFalling();
    render();
    startTimer();
  }, 500);
</script>

<style is:global>
  .wt-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .wt-scorebar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 0.5rem 1.25rem;
  }

  .wt-score-item strong {
    font-family: 'JetBrains Mono', monospace;
    color: var(--accent-cyan);
  }

  .wt-score-divider {
    color: var(--border-color);
  }

  .wt-grid {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    grid-template-rows: repeat(10, 1fr);
    gap: 2px;
    width: 400px;
    height: 500px;
    background: rgba(0, 0, 0, 0.5);
    border: 2px solid rgba(6, 182, 212, 0.3);
    border-radius: 10px;
    padding: 3px;
    box-shadow: 0 0 24px rgba(6, 182, 212, 0.12), inset 0 0 24px rgba(6, 182, 212, 0.04);
  }

  .wt-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(15, 23, 42, 0.7);
    border: 1px solid rgba(6, 182, 212, 0.08);
    border-radius: 4px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    font-weight: 700;
    color: transparent;
    transition: background 0.15s, border-color 0.15s;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    padding: 0 3px;
    cursor: default;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }

  .wt-cell.wt-filled { color: #cbd5e1; }

  .wt-cell.wt-filled.wt-en {
    background: #be185d;
    border-color: #f472b6;
    color: #fce7f3;
    cursor: pointer;
  }

  .wt-cell.wt-filled.wt-cn {
    background: #1d4ed8;
    border-color: #60a5fa;
    color: #dbeafe;
    cursor: pointer;
  }

  .wt-cell.wt-filled.wt-seed {
    background: #334155;
    border-color: #475569;
    color: #64748b;
    cursor: default;
  }

  .wt-cell.wt-falling {
    font-size: 0.78rem;
    font-weight: 800;
    animation: wtPulse 0.7s ease-in-out infinite;
    cursor: default;
  }

  .wt-cell.wt-falling.wt-falling-en {
    background: #ec4899;
    border-color: #fbcfe8;
    color: #fff;
    box-shadow: 0 0 18px rgba(236, 72, 153, 0.6), 0 0 40px rgba(236, 72, 153, 0.2);
  }

  .wt-cell.wt-falling.wt-falling-cn {
    background: #3b82f6;
    border-color: #bfdbfe;
    color: #fff;
    box-shadow: 0 0 18px rgba(59, 130, 246, 0.6), 0 0 40px rgba(59, 130, 246, 0.2);
  }

  @keyframes wtPulse {
    0%, 100% { opacity: 0.85; }
    50% { opacity: 1; }
  }

  .wt-cell.wt-wrong {
    background: #dc2626 !important;
    border-color: #fca5a5 !important;
    color: #fff !important;
    animation: none !important;
  }

  .wt-cell.wt-destroy {
    animation: wtDestroy 0.25s ease-out forwards;
  }

  @keyframes wtDestroy {
    0% { transform: scale(1); opacity: 1; background: #22c55e; }
    100% { transform: scale(0.2); opacity: 0; }
  }

  .wt-restart {
    padding: 0.5rem 1.5rem;
    border: 1px solid var(--border-color);
    border-radius: 10px;
    background: var(--bg-secondary);
    color: var(--text-secondary);
    font-size: 0.875rem;
    cursor: pointer;
    transition: var(--transition);
  }

  .wt-restart:hover {
    border-color: var(--accent-cyan);
    color: var(--accent-cyan);
  }

  .wt-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 200;
    backdrop-filter: blur(4px);
  }

  .wt-overlay.hidden { display: none; }

  .wt-overlay-box {
    text-align: center;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 2.5rem 3rem;
    box-shadow: 0 0 40px rgba(139, 92, 246, 0.3);
  }

  .wt-overlay-box h2 {
    font-size: 2rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent-purple), var(--accent-pink));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
  }

  .wt-final-score {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  .wt-final-score span {
    color: var(--accent-cyan);
    font-weight: 700;
    font-size: 1.5rem;
  }

  .wt-restart-btn {
    padding: 0.8rem 2rem;
    border: none;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--accent-purple), var(--accent-pink));
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.15s;
    box-shadow: 0 4px 15px rgba(139, 92, 246, 0.3);
  }

  .wt-restart-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(139, 92, 246, 0.5);
  }

  .wt-difficulty-select {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    color: var(--accent-cyan);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.15rem 0.4rem;
    cursor: pointer;
    outline: none;
    transition: border-color 0.15s;
  }

  .wt-difficulty-select:focus {
    border-color: var(--accent-purple);
    box-shadow: 0 0 8px rgba(139, 92, 246, 0.3);
  }

  @media (max-width: 500px) {
    .wt-grid { width: 320px; height: 400px; }
    .wt-cell { font-size: 0.6rem; }
    .wt-cell.wt-falling { font-size: 0.65rem; }
    .wt-scorebar { font-size: 0.75rem; padding: 0.4rem 1rem; gap: 0.5rem; }
  }
</style>
