</div>

<script>
  const COLS = 8;
  const ROWS = 10;
  const SPEED = 700;

  const GRADE_NAMES: Record<string, string> = {
    '1': '一年级', '2': '二年级', '3': '三年级', '4': '四年级', '5': '五年级', '6': '六年级',
    '7': '初一', '8': '初二', '9': '初三'
  };

  const levelDataEl = document.getElementById('wtLevelData');
  const ALL_LEVELS: Record<string, { en: string; cn: string; phon?: string }[]> = JSON.parse(levelDataEl!.dataset.levels || '{}');

  const LEVEL_ORDER: string[] = [];
  for (let g = 1; g <= 9; g++) {
    for (let s = 1; s <= 7; s++) {
      LEVEL_ORDER.push(`${g}-${s}`);
    }
  }

  type Cell = { en: string; cn: string; phon: string; lang: 'en' | 'cn'; fixed?: boolean } | null;

  const grid: Cell[][] = [];
  let falling: { col: number; row: number; en: string; cn: string; phon: string; lang: 'en' | 'cn' } | null = null;
  let nextEn = '';
  let nextCn = '';
  let nextPhon = '';
  let nextLang: 'en' | 'cn' = 'en';
  let lastCol = -1;
  let score = 0;
  let currentLevelIndex = 0;
  let currentLevelKey = '1-1';
  let currentLevelWords: { en: string; cn: string; phon?: string }[] = [];
  let eliminatedKeys: Set<string> = new Set();
  let timer: ReturnType<typeof setInterval> | null = null;
  let gameOver = false;
  let animating = false;
  const recentlyDropped: string[] = []; // Track last N word pair keys to avoid consecutive repeats
  const MAX_RECENT = 3;

  function flipLang(l: 'en' | 'cn'): 'en' | 'cn' {
    return l === 'en' ? 'cn' : 'en';
  }

  function loadLevel(levelKey: string) {
    currentLevelKey = levelKey;
    currentLevelWords = ALL_LEVELS[levelKey] || [];
  }

  function pickWord(): { en: string; cn: string; phon: string } {
    const pool = currentLevelWords.filter(w => !eliminatedKeys.has(w.en + ':' + w.cn));
    const i = Math.floor(Math.random() * pool.length);
    return { en: pool[i].en, cn: pool[i].cn, phon: pool[i].phon || '' };
  }

  function pickWordForGrid(): { en: string; cn: string; phon: string; lang: 'en' | 'cn' } {
    // Scan grid for all fixed cells, grouped by word pair with counts
    const pairStatus = new Map<string, { en: string; cn: string; enCount: number; cnCount: number }>();

    for (let r = 0; r < ROWS; r++) {
      for (let c = 0; c < COLS; c++) {
        const cell = grid[r][c];
        if (cell && cell.fixed) {
          const key = cell.en + ':' + cell.cn;
          if (!pairStatus.has(key)) {
            pairStatus.set(key, { en: cell.en, cn: cell.cn, enCount: 0, cnCount: 0 });
          }
          const status = pairStatus.get(key)!;
          if (cell.lang === 'en') {
            status.enCount++;
          } else {
            status.cnCount++;
          }
        }
      }
    }

    // Build candidates based on count imbalance per pair
    const candidates: { en: string; cn: string; lang: 'en' | 'cn' }[] = [];

    for (const [key, status] of pairStatus) {
      if (eliminatedKeys.has(key)) continue;

      if (status.enCount > status.cnCount) {
        // More en on grid, need cn to balance
        candidates.push({ en: status.en, cn: status.cn, lang: 'cn' });
      } else if (status.cnCount > status.enCount) {
        // More cn on grid, need en to balance
        candidates.push({ en: status.en, cn: status.cn, lang: 'en' });
      } else {
        // Balanced (both sides present equally) — either direction is valid
        candidates.push({ en: status.en, cn: status.cn, lang: 'cn' });
        candidates.push({ en: status.en, cn: status.cn, lang: 'en' });
      }
    }

    // Mix in random words from pool to break predictable patterns
    const onGridKeys = new Set(pairStatus.keys());
    const randomPool = currentLevelWords.filter(w => {
      const k = w.en + ':' + w.cn;
      return !eliminatedKeys.has(k) && !recentlyDropped.includes(k);
    });
    // Add up to 2 random words to candidates for variety
    const shuffledRandom = randomPool.sort(() => Math.random() - 0.5);
    for (let ri = 0; ri < Math.min(2, shuffledRandom.length); ri++) {
      const rw = shuffledRandom[ri];
      const rk = rw.en + ':' + rw.cn;
      if (!candidates.some(c => c.en + ':' + c.cn === rk)) {
        candidates.push({ en: rw.en, cn: rw.cn, lang: Math.random() < 0.5 ? 'en' : 'cn' });
      }
    }

    if (candidates.length > 0) {
      // Prefer candidates not recently dropped
      const fresh = candidates.filter(c => !recentlyDropped.includes(c.en + ':' + c.cn));
      if (fresh.length > 0) {
        const picked = fresh[Math.floor(Math.random() * fresh.length)];
        const word = currentLevelWords.find(w => w.en === picked.en && w.cn === picked.cn);
        return { ...picked, phon: word?.phon || '' };
      }
      // All candidates recently dropped — fall through to random pool
    }

    // Fall back to random, excluding eliminated and recently dropped words
    const pool = currentLevelWords.filter(w => {
      const k = w.en + ':' + w.cn;
      return !eliminatedKeys.has(k) && !recentlyDropped.includes(k);
    });
    // Prefer words not already on grid
    const preferred = pool.filter(w => !onGridKeys.has(w.en + ':' + w.cn));
    const pickPool = preferred.length > 0 ? preferred : pool;
    if (pickPool.length === 0) {
      // All words exhausted or recently dropped — allow recently dropped but never eliminated
      const emergency = currentLevelWords.filter(w => !eliminatedKeys.has(w.en + ':' + w.cn));
      if (emergency.length === 0) return { en: '', cn: '', phon: '', lang: 'en' };
      const i = Math.floor(Math.random() * emergency.length);
      return {
        en: emergency[i].en, cn: emergency[i].cn, phon: emergency[i].phon || '',
        lang: Math.random() < 0.5 ? 'en' : 'cn',
      };
    }
    const i = Math.floor(Math.random() * pickPool.length);
    return {
      en: pickPool[i].en, cn: pickPool[i].cn, phon: pickPool[i].phon || '',
      lang: Math.random() < 0.5 ? 'en' : 'cn',
    };
  }

  function checkLevelComplete(): boolean {
    return currentLevelWords.filter(w => !eliminatedKeys.has(w.en + ':' + w.cn)).length === 0;
  }

  function updateLevelLabel() {
    document.getElementById('wtLevelLabel')!.textContent = currentLevelKey;
  }

  function showLevelFlash() {
    const el = document.getElementById('wtLevelFlash')!;
    const grade = currentLevelKey.split('-')[0];
    const gradeName = GRADE_NAMES[grade] || grade;
    document.getElementById('wtLevelFlashText')!.textContent = `${gradeName} - ${currentLevelKey}`;
    el.classList.remove('hidden');
    setTimeout(() => el.classList.add('hidden'), 1500);
  }

  function advanceLevel() {
    currentLevelIndex++;
    if (currentLevelIndex >= LEVEL_ORDER.length) {
      document.getElementById('wtOverlayTitle')!.textContent = '全部通关!';
      endGame();
      return;
    }
    if (timer) { clearInterval(timer); timer = null; }
    const nextKey = LEVEL_ORDER[currentLevelIndex];
    loadLevel(nextKey);
    showLevelFlash();
    updateLevelLabel();
    falling = null;
    lastCol = -1;
    recentlyDropped.length = 0; // Clear recent history on level advance
    initGrid();
    updateScore();
    updateWordCount();
    render();
    const w = pickWordForGrid();
    nextEn = w.en;
    nextCn = w.cn;
    nextPhon = w.phon;
    nextLang = w.lang;
    setTimeout(() => {
      if (gameOver) return;
      spawnFalling();
      render();
      startTimer();
    }, 1600);
  }

  function pickBestColumn(): number {
    const heights: number[] = [];
    for (let c = 0; c < COLS; c++) {
      let h = 0;
      for (let r = ROWS - 1; r >= 0 && grid[r][c] !== null; r--, h++) {}
      heights.push(h);
    }
    const minH = Math.min(...heights);
    const candidates: number[] = [];
    for (let c = 0; c < COLS; c++) {
      if (heights[c] === minH) candidates.push(c);
    }
    for (const c of candidates) {
      if (c > lastCol) { lastCol = c; return c; }
    }
    lastCol = candidates[0];
    return candidates[0];
  }

  function initGrid() {
    for (let r = 0; r < ROWS; r++) {
      grid[r] = [];
      for (let c = 0; c < COLS; c++) {
        grid[r][c] = null;
      }
    }
  }

  function spawnFalling() {
    let en = nextEn;
    let cn = nextCn;
    let phon = nextPhon;
    let lang = nextLang;

    // If the queued word was already eliminated, pick a new one
    if (eliminatedKeys.has(en + ':' + cn)) {
      const fresh = pickWordForGrid();
      en = fresh.en;
      cn = fresh.cn;
      phon = fresh.phon;
      lang = fresh.lang;
    }

    // Record current word as recently dropped
    const key = en + ':' + cn;
    recentlyDropped.push(key);
    if (recentlyDropped.length > MAX_RECENT) {
      recentlyDropped.shift();
    }

    // Pick next word based on grid state (prefer unpaired counterparts)
    const next = pickWordForGrid();
    nextEn = next.en;
    nextCn = next.cn;
    nextPhon = next.phon;
    nextLang = next.lang;

    const col = pickBestColumn();
    if (grid[0][col] !== null) {
      endGame();
      return;
    }
    falling = { col, row: 0, en, cn, phon, lang };
  }

  function canMoveDown(): boolean {
    if (!falling) return false;
    const nextRow = falling.row + 1;
    if (nextRow >= ROWS) return false;
    return grid[nextRow][falling.col] === null;
  }

  function applyGravity(col: number) {
    for (let r = ROWS - 2; r >= 0; r--) {
      if (grid[r][col] !== null && grid[r + 1][col] === null) {
        grid[r + 1][col] = grid[r][col];
        grid[r][col] = null;
      }
    }
  }

  function fixFalling() {
    if (!falling) return;
    grid[falling.row][falling.col] = {
      en: falling.en, cn: falling.cn, phon: falling.phon, lang: falling.lang, fixed: true,
    };
    falling = null;
    if (checkGameOver()) return;
    spawnFalling();
  }

  function checkGameOver(): boolean {
    if (grid[0].some((cell) => cell !== null)) {
      endGame();
      return true;
    }
    return false;
  }

  function endGame() {
    gameOver = true;
    if (timer) { clearInterval(timer); timer = null; }
    document.getElementById('wtOverlayTitle')!.textContent = '挑战失败';
    document.getElementById('wtFinalScore')!.textContent = String(score);
    document.getElementById('wtOverlay')!.classList.remove('hidden');
  }

  function updateScore() {
    document.getElementById('wtScore')!.textContent = String(score);
  }

  function updateWordCount() {
    const total = currentLevelWords.length;
    const completed = currentLevelWords.filter(w => eliminatedKeys.has(w.en + ':' + w.cn)).length;
    document.getElementById('wtCompleted')!.textContent = String(completed);
    document.getElementById('wtTotal')!.textContent = String(total);
  }

  function render() {
    const gridEl = document.getElementById('wtGrid')!;
    let html = '';
    for (let r = 0; r < ROWS; r++) {
      for (let c = 0; c < COLS; c++) {
        const cell = grid[r][c];
        let cls = 'wt-cell';
        let wordText = '';
        let phonText = '';
        if (cell) {
          cls += ' wt-filled';
          if (cell.cn === '') {
            cls += ' wt-seed';
          } else if (cell.lang === 'en') {
            cls += ' wt-en';
            wordText = cell.en;
            phonText = cell.phon || '';
          } else {
            cls += ' wt-cn';
            wordText = cell.cn;
          }
        }
        if (falling && falling.row === r && falling.col === c) {
          cls += ' wt-falling';
          if (falling.lang === 'en') {
            cls += ' wt-falling-en';
            wordText = falling.en;
            phonText = falling.phon || '';
          } else {
            cls += ' wt-falling-cn';
            wordText = falling.cn;
          }
        }
        html += `<div class="${cls}"><span class="wt-word">${wordText}</span>${phonText ? `<span class="wt-phon">${phonText}</span>` : ''}</div>`;
      }
    }
    gridEl.innerHTML = html;

    gridEl.querySelectorAll('.wt-filled:not(.wt-seed):not(.wt-falling)').forEach((el) => {
      el.addEventListener('click', () => {
        if (gameOver || animating || !falling) return;
        const idx = Array.from(gridEl.children).indexOf(el);
        const r = Math.floor(idx / COLS);
        const c = idx % COLS;
        const cell = grid[r][c];
        if (!cell || !cell.fixed) return;
        if (cell.en === falling.en && cell.cn === falling.cn && cell.lang !== falling.lang) {
          handlePairMatch(r, c);
        } else {
          handleGridWrong(el as HTMLElement);
        }
      });
    });
  }

  function handlePairMatch(r: number, c: number) {
    if (!falling) return;
    const eliminatedKey = falling.en + ':' + falling.cn;
    eliminatedKeys.add(eliminatedKey);
    recentlyDropped.push(eliminatedKey);
    if (recentlyDropped.length > MAX_RECENT) {
      recentlyDropped.shift();
    }
    grid[r][c] = null;
    falling = null;
    score += 10;
    updateScore();
    updateWordCount();
    animateDestroy();
    render();
    applyGravity(c);
    render();
    if (checkLevelComplete()) {
      advanceLevel();
      return;
    }
    if (!gameOver) spawnFalling();
    render();
  }

  function handleGridWrong(el: HTMLElement) {
    if (!falling) return;
    score = Math.max(0, score - 2);
    updateScore();
    animating = true;
    const fallingCell = document.querySelector('.wt-falling') as HTMLElement;
    if (fallingCell) fallingCell.classList.add('wt-wrong');
    el.classList.add('wt-wrong');
    setTimeout(() => {
      if (fallingCell) fallingCell.classList.remove('wt-wrong');
      el.classList.remove('wt-wrong');
      animating = false;
    }, 400);
  }

  function animateDestroy() {
    const fallingCell = document.querySelector('.wt-falling') as HTMLElement;
    if (fallingCell) fallingCell.classList.add('wt-destroy');
  }

  function tick() {
    if (gameOver) return;
    if (!falling) return;
    if (canMoveDown()) {
      falling.row++;
      render();
    } else {
      fixFalling();
      render();
    }
  }

  function startTimer() {
    if (timer) clearInterval(timer);
    timer = setInterval(tick, SPEED);
  }

  function dropNow() {
    if (gameOver || !falling) return;
    while (canMoveDown()) { falling.row++; }
    fixFalling();
    render();
  }

  function restart() {
    if (timer) { clearInterval(timer); timer = null; }
    const selectedLevel = (document.getElementById('wtDifficulty') as HTMLSelectElement).value;
    currentLevelIndex = LEVEL_ORDER.indexOf(selectedLevel);
    if (currentLevelIndex === -1) currentLevelIndex = 0;
    loadLevel(LEVEL_ORDER[currentLevelIndex]);
    eliminatedKeys = new Set();
    gameOver = false;
    animating = false;
    score = 0;
    falling = null;
    lastCol = -1;
    recentlyDropped.length = 0; // Clear recent history on restart
    initGrid();
    const w = pickWordForGrid();
    nextEn = w.en;
    nextCn = w.cn;
    nextPhon = w.phon;
    nextLang = w.lang;
    updateScore();
    updateWordCount();
    updateLevelLabel();
    render();
    document.getElementById('wtOverlay')!.classList.add('hidden');
    spawnFalling();
    render();
    startTimer();
  }

  document.getElementById('wtDrop')!.addEventListener('click', dropNow);
  document.getElementById('wtRestart')!.addEventListener('click', restart);
  document.getElementById('wtOverlayRestart')!.addEventListener('click', restart);
  document.getElementById('wtDifficulty')!.addEventListener('change', restart);

  function showStudyModal() {
    if (timer) { clearInterval(timer); timer = null; }
    gameOver = true;
    const list = document.getElementById('wtStudyList')!;
    const title = document.getElementById('wtStudyTitle')!;
    const grade = currentLevelKey.split('-')[0];
    const gradeName = GRADE_NAMES[grade] || grade;
    title.textContent = `${gradeName} - 关卡 ${currentLevelKey} - 学习复习`;
    let html = '<div class="wt-study-table"><div class="wt-study-row wt-study-header-row"><div class="wt-study-cell wt-study-en">English</div><div class="wt-study-cell wt-study-phon">Phonetic</div><div class="wt-study-cell wt-study-cn">中文</div></div>';
    currentLevelWords.forEach(w => {
      html += `<div class="wt-study-row"><div class="wt-study-cell wt-study-en">${w.en}</div><div class="wt-study-cell wt-study-phon">${w.phon || ''}</div><div class="wt-study-cell wt-study-cn">${w.cn}</div></div>`;
    });
    html += '</div>';
    list.innerHTML = html;
    document.getElementById('wtStudyOverlay')!.classList.remove('hidden');
  }

  function closeStudyModal() {
    document.getElementById('wtStudyOverlay')!.classList.add('hidden');
  }

  document.getElementById('wtStudy')!.addEventListener('click', showStudyModal);
  document.getElementById('wtStudyClose')!.addEventListener('click', closeStudyModal);
  document.getElementById('wtStudyStart')!.addEventListener('click', () => {
    closeStudyModal();
    restart();
  });

  // Initialize
  currentLevelIndex = 0;
  loadLevel('1-1');
  initGrid();
  const w0 = pickWord();
  nextEn = w0.en;
  nextCn = w0.cn;
  nextPhon = w0.phon;
  nextLang = Math.random() < 0.5 ? 'en' : 'cn';
  updateScore();
  updateWordCount();
  updateLevelLabel();
  render();

  setTimeout(() => {
    spawnFalling();
    render();
    startTimer();
  }, 500);
</script>

