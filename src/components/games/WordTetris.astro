<div class="wt-wrapper">
  <div class="wt-scorebar">
    <span class="wt-score-item">得分 <strong id="wtScore">0</strong></span>
    <span class="wt-score-divider">|</span>
    <span class="wt-score-item">速度 Lv.<strong id="wtLevel">1</strong></span>
    <span class="wt-score-item wt-score-right" id="wtInterval">1.2s</span>
  </div>
  <div class="wt-grid" id="wtGrid"></div>
  <button class="wt-restart" id="wtRestart">重新开始</button>
</div>

<div class="wt-overlay hidden" id="wtOverlay">
  <div class="wt-overlay-box">
    <h2>Game Over</h2>
    <p class="wt-final-score">最终得分: <span id="wtFinalScore">0</span></p>
    <button class="wt-restart-btn" id="wtOverlayRestart">再来一局</button>
  </div>
</div>

<script>
  const COLS = 8;
  const ROWS = 10;
  const START_SPEED = 1200;
  const MIN_SPEED = 400;
  const SPEED_STEP = 100;

  const VOCAB: [string, string][] = [
    ['apple','苹果'],['book','书本'],['cat','猫'],['dog','狗'],
    ['fish','鱼'],['bird','鸟'],['tree','树'],['star','星星'],
    ['moon','月亮'],['sun','太阳'],['cloud','云朵'],['rain','雨'],
    ['snow','雪'],['wind','风'],['fire','火'],['water','水'],
    ['house','房子'],['school','学校'],['teacher','老师'],['student','学生'],
    ['happy','快乐'],['big','大'],['small','小'],['hot','热'],['cold','冷'],
  ];

  type Cell = { en: string; cn: string; lang: 'en' | 'cn'; fixed?: boolean } | null;

  const grid: Cell[][] = [];
  let falling: { col: number; row: number; en: string; cn: string; lang: 'en' | 'cn' } | null = null;
  let nextEn = '';
  let nextCn = '';
  let nextLang: 'en' | 'cn' = 'en';
  let score = 0;
  let speed = START_SPEED;
  let timer: ReturnType<typeof setInterval> | null = null;
  let gameOver = false;
  let animating = false;

  function randLang(): 'en' | 'cn' {
    return Math.random() < 0.5 ? 'en' : 'cn';
  }

  function initGrid() {
    for (let r = 0; r < ROWS; r++) {
      grid[r] = [];
      for (let c = 0; c < COLS; c++) {
        grid[r][c] = null;
      }
    }
    const seedRows = 1 + Math.floor(Math.random() * 2);
    const letters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    for (let r = ROWS - seedRows; r < ROWS; r++) {
      for (let c = 0; c < COLS; c++) {
        const li = Math.floor(Math.random() * letters.length);
        grid[r][c] = { en: letters[li], cn: '', lang: 'en', fixed: true };
      }
    }
  }

  function pickWord() {
    const i = Math.floor(Math.random() * VOCAB.length);
    return { en: VOCAB[i][0], cn: VOCAB[i][1] };
  }

  function spawnFalling() {
    const en = nextEn;
    const cn = nextCn;
    const lang = nextLang;
    const next = pickWord();
    nextEn = next.en;
    nextCn = next.cn;
    nextLang = randLang();

    const col = Math.floor(Math.random() * COLS);
    if (grid[0][col] !== null) {
      endGame();
      return;
    }
    falling = { col, row: 0, en, cn, lang };
  }

  function canMoveDown(): boolean {
    if (!falling) return false;
    const nextRow = falling.row + 1;
    if (nextRow >= ROWS) return false;
    return grid[nextRow][falling.col] === null;
  }

  function fixFalling() {
    if (!falling) return;
    grid[falling.row][falling.col] = {
      en: falling.en, cn: falling.cn, lang: falling.lang, fixed: true,
    };
    falling = null;
    checkElimination();
    checkGameOver();
    if (!gameOver) spawnFalling();
  }

  function checkElimination() {
    const fullRows: number[] = [];
    for (let r = ROWS - 1; r >= 0; r--) {
      if (grid[r].every((cell) => cell !== null)) {
        fullRows.push(r);
      }
    }
    if (fullRows.length === 0) return;

    const cells = document.querySelectorAll('.wt-cell');
    for (const r of fullRows) {
      for (let c = 0; c < COLS; c++) {
        const idx = r * COLS + c;
        cells[idx]?.classList.add('flash');
      }
    }

    if (timer) clearInterval(timer);
    setTimeout(() => {
      fullRows.sort((a, b) => b - a);
      for (const r of fullRows) {
        grid.splice(r, 1);
        grid.unshift(new Array(COLS).fill(null));
        score += 20;
      }
      updateScore();
      if (!falling && !gameOver) spawnFalling();
      render();
      startTimer();
    }, 300);
  }

  function checkGameOver() {
    if (grid[0].some((cell) => cell !== null)) {
      endGame();
    }
  }

  function endGame() {
    gameOver = true;
    if (timer) { clearInterval(timer); timer = null; }
    document.getElementById('wtFinalScore')!.textContent = String(score);
    document.getElementById('wtOverlay')!.classList.remove('hidden');
  }

  function updateScore() {
    document.getElementById('wtScore')!.textContent = String(score);
    const oldSpeed = speed;
    const level = Math.floor(score / 50) + 1;
    speed = Math.max(MIN_SPEED, START_SPEED - (level - 1) * SPEED_STEP);
    document.getElementById('wtLevel')!.textContent = String(level);
    document.getElementById('wtInterval')!.textContent = (speed / 1000).toFixed(1) + 's';
    if (oldSpeed !== speed && !gameOver && timer) {
      clearInterval(timer);
      timer = setInterval(tick, speed);
    }
  }

  function render() {
    const gridEl = document.getElementById('wtGrid')!;
    let html = '';
    for (let r = 0; r < ROWS; r++) {
      for (let c = 0; c < COLS; c++) {
        const cell = grid[r][c];
        let cls = 'wt-cell';
        let text = '';
        if (cell) {
          cls += ' wt-filled';
          if (cell.cn === '') {
            cls += ' wt-seed';
          } else if (cell.lang === 'en') {
            cls += ' wt-en';
          } else {
            cls += ' wt-cn';
          }
          text = cell.lang === 'en' ? cell.en : cell.cn;
        }
        if (falling && falling.row === r && falling.col === c) {
          cls += ' wt-falling';
          if (falling.lang === 'en') cls += ' wt-falling-en';
          else cls += ' wt-falling-cn';
          text = falling.lang === 'en' ? falling.en : falling.cn;
        }
        html += `<div class="${cls}">${text}</div>`;
      }
    }
    gridEl.innerHTML = html;

    gridEl.querySelectorAll('.wt-filled:not(.wt-seed):not(.wt-falling)').forEach((el) => {
      el.addEventListener('click', () => {
        if (gameOver || animating || !falling) return;
        const idx = Array.from(gridEl.children).indexOf(el);
        const r = Math.floor(idx / COLS);
        const c = idx % COLS;
        const cell = grid[r][c];
        if (!cell || !cell.fixed) return;
        if (cell.en === falling.en && cell.cn === falling.cn) {
          handlePairMatch(r, c);
        } else {
          handleGridWrong(el as HTMLElement);
        }
      });
    });
  }

  function handlePairMatch(r: number, c: number) {
    if (!falling) return;
    grid[r][c] = null;
    falling = null;
    score += 10;
    updateScore();
    animateDestroy();
    render();
    checkElimination();
    if (!gameOver && !falling) spawnFalling();
    render();
  }

  function handleGridWrong(el: HTMLElement) {
    if (!falling) return;
    score = Math.max(0, score - 2);
    updateScore();
    animating = true;
    const fallingCell = document.querySelector('.wt-falling') as HTMLElement;
    if (fallingCell) fallingCell.classList.add('wt-wrong');
    el.classList.add('wt-wrong');
    setTimeout(() => {
      if (fallingCell) fallingCell.classList.remove('wt-wrong');
      el.classList.remove('wt-wrong');
      animating = false;
    }, 400);
  }

  function animateDestroy() {
    const fallingCell = document.querySelector('.wt-falling') as HTMLElement;
    if (fallingCell) fallingCell.classList.add('wt-destroy');
  }

  function tick() {
    if (gameOver) return;
    if (!falling) return;
    if (canMoveDown()) {
      falling.row++;
      render();
    } else {
      fixFalling();
      render();
    }
  }

  function startTimer() {
    if (timer) clearInterval(timer);
    timer = setInterval(tick, speed);
  }

  function restart() {
    if (timer) { clearInterval(timer); timer = null; }
    gameOver = false;
    animating = false;
    score = 0;
    speed = START_SPEED;
    falling = null;
    initGrid();
    nextEn = pickWord().en;
    nextCn = pickWord().cn;
    nextLang = randLang();
    updateScore();
    render();
    document.getElementById('wtOverlay')!.classList.add('hidden');
    spawnFalling();
    render();
    startTimer();
  }

  document.getElementById('wtRestart')!.addEventListener('click', restart);
  document.getElementById('wtOverlayRestart')!.addEventListener('click', restart);

  initGrid();
  nextEn = pickWord().en;
  nextCn = pickWord().cn;
  nextLang = randLang();
  updateScore();
  render();

  setTimeout(() => {
    spawnFalling();
    render();
    startTimer();
  }, 500);
</script>

<style>
  .wt-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .wt-scorebar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 0.5rem 1.25rem;
  }

  .wt-score-item strong {
    font-family: 'JetBrains Mono', monospace;
    color: var(--accent-cyan);
  }

  .wt-score-divider {
    color: var(--border-color);
  }

  .wt-score-right {
    margin-left: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .wt-grid {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    grid-template-rows: repeat(10, 1fr);
    gap: 2px;
    width: 360px;
    height: 450px;
    background: rgba(0, 0, 0, 0.4);
    border: 2px solid rgba(6, 182, 212, 0.4);
    border-radius: 8px;
    padding: 2px;
    box-shadow: 0 0 20px rgba(6, 182, 212, 0.15), inset 0 0 20px rgba(6, 182, 212, 0.05);
  }

  .wt-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(6, 182, 212, 0.1);
    border-radius: 3px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    font-weight: 600;
    color: transparent;
    transition: background 0.15s, border-color 0.15s;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    padding: 0 2px;
    cursor: default;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }

  .wt-cell.wt-filled { color: #94a3b8; }

  .wt-cell.wt-filled.wt-en {
    background: rgba(236, 72, 153, 0.25);
    border-color: rgba(236, 72, 153, 0.35);
    color: #f9a8d4;
    cursor: pointer;
  }

  .wt-cell.wt-filled.wt-cn {
    background: rgba(59, 130, 246, 0.25);
    border-color: rgba(59, 130, 246, 0.35);
    color: #93c5fd;
    cursor: pointer;
  }

  .wt-cell.wt-filled.wt-seed {
    background: rgba(51, 65, 85, 0.5);
    color: #64748b;
    cursor: default;
  }

  .wt-cell.wt-falling {
    font-size: 0.75rem;
    animation: wtPulse 0.8s ease-in-out infinite;
    cursor: default;
  }

  .wt-cell.wt-falling.wt-falling-en {
    background: rgba(236, 72, 153, 0.5);
    border-color: var(--accent-pink);
    color: #fbcfe8;
    box-shadow: 0 0 14px rgba(236, 72, 153, 0.5);
  }

  .wt-cell.wt-falling.wt-falling-cn {
    background: rgba(59, 130, 246, 0.5);
    border-color: var(--accent-blue);
    color: #bfdbfe;
    box-shadow: 0 0 14px rgba(59, 130, 246, 0.5);
  }

  @keyframes wtPulse {
    0%, 100% { opacity: 0.8; }
    50% { opacity: 1; }
  }

  .wt-cell.wt-wrong {
    background: rgba(239, 68, 68, 0.6) !important;
    border-color: #ef4444 !important;
    color: #fca5a5 !important;
    animation: none !important;
  }

  .wt-cell.wt-destroy {
    animation: wtDestroy 0.3s ease-out forwards;
  }

  @keyframes wtDestroy {
    0% { transform: scale(1); opacity: 1; background: rgba(16, 185, 129, 0.6); }
    100% { transform: scale(0.3); opacity: 0; }
  }

  .wt-cell.flash {
    animation: wtFlash 0.15s ease-in-out 2;
  }

  @keyframes wtFlash {
    0%, 100% { background: rgba(255, 255, 255, 0.3); }
    50% { background: rgba(255, 255, 255, 0.9); }
  }

  .wt-restart {
    padding: 0.5rem 1.5rem;
    border: 1px solid var(--border-color);
    border-radius: 10px;
    background: var(--bg-secondary);
    color: var(--text-secondary);
    font-size: 0.875rem;
    cursor: pointer;
    transition: var(--transition);
  }

  .wt-restart:hover {
    border-color: var(--accent-cyan);
    color: var(--accent-cyan);
  }

  .wt-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 200;
    backdrop-filter: blur(4px);
  }

  .wt-overlay.hidden { display: none; }

  .wt-overlay-box {
    text-align: center;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 2.5rem 3rem;
    box-shadow: 0 0 40px rgba(139, 92, 246, 0.3);
  }

  .wt-overlay-box h2 {
    font-size: 2rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent-purple), var(--accent-pink));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
  }

  .wt-final-score {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  .wt-final-score span {
    color: var(--accent-cyan);
    font-weight: 700;
    font-size: 1.5rem;
  }

  .wt-restart-btn {
    padding: 0.8rem 2rem;
    border: none;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--accent-purple), var(--accent-pink));
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.15s;
    box-shadow: 0 4px 15px rgba(139, 92, 246, 0.3);
  }

  .wt-restart-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(139, 92, 246, 0.5);
  }

  @media (max-width: 500px) {
    .wt-grid { width: 320px; height: 400px; }
    .wt-cell { font-size: 0.6rem; }
    .wt-cell.wt-falling { font-size: 0.65rem; }
    .wt-scorebar { font-size: 0.75rem; padding: 0.4rem 1rem; gap: 0.5rem; }
  }
</style>
