---
interface Props {
  items: Array<{
    slug: string;
    name: string;
    description: string;
    category: string;
    href: string;
    status?: string;
  }>;
  title?: string;
}

const { items, title } = Astro.props;
---

{title && <h2 class="section-title">{title}</h2>}

<div class="card-grid">
  {items.map((item) => (
    <a href={item.status === 'coming-soon' ? '#' : item.href} class:list={['card', { 'card-coming': item.status === 'coming-soon' }]}>
      <h3 class="card-name">{item.name}</h3>
      <p class="card-desc">{item.description}</p>
      <span class="card-category">{item.category}</span>
    </a>
  ))}
</div>

<style>
  .section-title {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
  }
  
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  
  .card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    padding: 1.25rem;
    transition: var(--transition);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .card:hover:not(.card-coming) {
    border-color: var(--accent-blue);
    box-shadow: var(--shadow-hover);
  }
  
  .card-coming {
    opacity: 0.5;
    cursor: not-allowed;
  }
  
  .card-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
  }
  
  .card-desc {
    color: var(--text-secondary);
    font-size: 0.875rem;
    line-height: 1.5;
    flex: 1;
  }
  
  .card-category {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
  }
</style>
