---
import { getCollection } from 'astro:content';
import tools from '../data/tools.json';
import games from '../data/games.json';

const docsCollection = await getCollection('docs');

const searchData = {
  items: [
    ...tools.map((t) => ({
      type: 'tool',
      label: '工具',
      title: t.name,
      desc: t.description,
      category: t.category,
      href: `/tools/${t.slug}`,
      searchable: `${t.name} ${t.description} ${t.category}`,
    })),
    ...games.map((g) => ({
      type: 'game',
      label: '游戏',
      title: g.name,
      desc: g.description,
      category: g.category,
      href: `/games/${g.slug}`,
      searchable: `${g.name} ${g.description} ${g.category}`,
    })),
    ...docsCollection.map((d) => ({
      type: 'doc',
      label: '文档',
      title: d.data.title,
      desc: d.data.description,
      category: d.data.category,
      href: `/docs/${d.slug}`,
      searchable: `${d.data.title} ${d.data.description} ${d.data.category}`,
    })),
  ],
};
---

<div class="search-overlay hidden" id="searchOverlay">
  <div class="search-modal">
    <div class="search-header">
      <svg class="search-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input type="text" id="searchInput" class="search-input" placeholder="搜索工具、游戏、文档..." autocomplete="off" />
      <kbd class="kbd">ESC</kbd>
    </div>
    
    <div class="search-body" id="searchResults">
      <div class="search-empty">输入关键词开始搜索</div>
    </div>
    
    <div class="search-footer">
      <span><kbd class="kbd">↑↓</kbd> 导航</span>
      <span><kbd class="kbd">Enter</kbd> 打开</span>
      <span><kbd class="kbd">Ctrl+K</kbd> 呼出</span>
    </div>
  </div>
</div>

<script define:vars={{ searchData }}>
  const allItems = searchData.items;
  const overlay = document.getElementById('searchOverlay');
  const input = document.getElementById('searchInput');
  const results = document.getElementById('searchResults');
  
  let activeIndex = -1;

  function toggleSearch(show) {
    const isHidden = overlay.classList.contains('hidden');
    const isVisible = show ?? isHidden;
    
    if (isVisible) {
      overlay.classList.remove('hidden');
      overlay.classList.add('visible');
      setTimeout(() => input.focus(), 100);
    } else {
      overlay.classList.remove('visible');
      overlay.classList.add('hidden');
      activeIndex = -1;
      input.value = '';
      results.innerHTML = '<div class="search-empty">输入关键词开始搜索</div>';
    }
  }

  function fuzzyMatch(query, text) {
    const q = query.toLowerCase();
    const t = text.toLowerCase();
    let qi = 0;
    for (let i = 0; i < t.length && qi < q.length; i++) {
      if (t[i] === q[qi]) qi++;
    }
    return qi === q.length;
  }

  function highlightMatch(query, text) {
    const q = query.toLowerCase();
    const t = text.toLowerCase();
    let result = '';
    let qi = 0;
    for (let i = 0; i < t.length; i++) {
      if (qi < q.length && t[i] === q[qi]) {
        result += '<mark>' + text[i] + '</mark>';
        qi++;
      } else {
        result += text[i];
      }
    }
    return result;
  }

  function renderResults(query) {
    if (!query.trim()) {
      results.innerHTML = '<div class="search-empty">输入关键词开始搜索</div>';
      activeIndex = -1;
      return;
    }

    const filtered = allItems.filter((item) => {
      const ql = query.toLowerCase();
      return item.searchable.toLowerCase().includes(ql) || fuzzyMatch(ql, item.searchable);
    });

    if (filtered.length === 0) {
      results.innerHTML = '<div class="search-empty">未找到匹配项</div>';
      activeIndex = -1;
      return;
    }

    const groups = {};
    for (const item of filtered) {
      if (!groups[item.label]) groups[item.label] = [];
      groups[item.label].push(item);
    }

    let html = '';
    let idx = 0;
    const typeColors = { '工具': 'var(--accent-cyan)', '游戏': 'var(--accent-purple)', '文档': 'var(--accent-green)' };

    for (const [group, items] of Object.entries(groups)) {
      html += '<div class="search-group">';
      html += '<span class="search-group-label">' + group + '</span>';
      for (const item of items) {
        html += '<div class="search-item" data-idx="' + idx + '" data-href="' + item.href + '">';
        html += '<div class="search-item-info">';
        html += '<span class="search-item-title">' + highlightMatch(query, item.title) + '</span>';
        html += '<span class="search-item-desc">' + highlightMatch(query, item.desc) + '</span>';
        html += '</div>';
        html += '<span class="search-item-cat" style="color:' + typeColors[group] + '">' + item.category + '</span>';
        html += '</div>';
        idx++;
      }
      html += '</div>';
    }

    results.innerHTML = html;
    activeIndex = -1;
  }

  function navigate(direction) {
    const items = results.querySelectorAll('.search-item');
    if (items.length === 0) return;
    if (activeIndex >= 0) items[activeIndex].classList.remove('active');
    activeIndex = (activeIndex + direction + items.length) % items.length;
    items[activeIndex].classList.add('active');
    items[activeIndex].scrollIntoView({ block: 'nearest' });
  }

  input.addEventListener('input', (e) => renderResults(e.target.value));

  input.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown') { e.preventDefault(); navigate(1); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); navigate(-1); }
    else if (e.key === 'Enter') { e.preventDefault(); const item = results.querySelector('[data-idx="' + activeIndex + '"]'); if (item && item.dataset.href) window.location.href = item.dataset.href; }
  });

  results.addEventListener('click', (e) => {
    const item = e.target.closest('.search-item');
    if (item && item.dataset.href) window.location.href = item.dataset.href;
  });

  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) toggleSearch(false);
  });

  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') { e.preventDefault(); toggleSearch(true); }
    if (e.key === 'Escape' && overlay.classList.contains('visible')) toggleSearch(false);
  });
</script>

<style>
  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 15vh;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s ease;
  }

  .search-overlay.visible {
    opacity: 1;
    pointer-events: auto;
  }
  
  .search-overlay.hidden {
    display: none;
  }

  .search-modal {
    width: 90%;
    max-width: 640px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    overflow: hidden;
  }
  
  .search-header {
    display: flex;
    align-items: center;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border-color);
    gap: 0.75rem;
  }

  .search-icon-svg {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--text-primary);
    font-size: 1rem;
    outline: none;
  }

  .search-body {
    max-height: 420px;
    overflow-y: auto;
    padding: 0.5rem;
  }

  .search-empty {
    padding: 2rem;
    text-align: center;
    color: var(--text-muted);
  }

  .search-group {
    margin-bottom: 0.5rem;
  }

  .search-group-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    padding: 0.5rem 0.75rem 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .search-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.1s;
  }

  .search-item.active,
  .search-item:hover {
    background: var(--bg-tertiary);
  }

  .search-item-info {
    flex: 1;
    min-width: 0;
  }

  .search-item-title {
    display: block;
    font-weight: 500;
    color: var(--text-primary);
    font-size: 0.875rem;
  }

  .search-item-title mark {
    background: rgba(59, 130, 246, 0.4);
    color: var(--accent-blue);
    padding: 0 1px;
    border-radius: 2px;
  }

  .search-item-desc {
    display: block;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 2px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .search-item-cat {
    font-size: 0.75rem;
    white-space: nowrap;
    background: var(--bg-primary);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }

  .search-footer {
    display: flex;
    gap: 1rem;
    padding: 0.75rem 1.25rem;
    border-top: 1px solid var(--border-color);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .kbd {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 0.1rem 0.4rem;
    font-size: 0.7rem;
    color: var(--text-muted);
    font-family: inherit;
  }

  .search-footer .search-footer-item,
  .search-footer > span {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
</style>
