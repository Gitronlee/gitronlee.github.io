---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <p>© {year} Web Toolbox. Built with Astro.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    padding: 2rem 0;
    margin-top: auto;
    text-align: center;
    color: var(--text-muted);
  }
  
  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
</style>
