---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <p>© {year} Web Toolbox. Built with Astro.</p>
    </div>
    <div class="footer-stats">
      <span class="stat-item" id="visitorStats" title="页面访问统计">
        <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
        <span class="stat-text">加载中...</span>
      </span>
    </div>
  </div>
</footer>

<script>
  function getVisits(): number {
    try {
      return parseInt(localStorage.getItem('tb_visits') || '0', 10);
    } catch { return 0; }
  }

  function getFirstVisit(): string | null {
    try { return localStorage.getItem('tb_first_visit'); } catch { return null; }
  }

  function initCounter() {
    const el = document.getElementById('visitorStats');
    if (!el) return;

    let count = getVisits();
    count++;
    try {
      localStorage.setItem('tb_visits', String(count));
    } catch {}

    const firstVisit = getFirstVisit();
    const today = new Date().toISOString().slice(0, 10);
    if (!firstVisit) {
      try { localStorage.setItem('tb_first_visit', today); } catch {}
    }

    el.querySelector('.stat-text')!.textContent = `你已访问 ${count} 次`;
    el.title = firstVisit ? `首次访问: ${firstVisit}` : `首次访问: ${today}`;
  }

  initCounter();
</script>

<style>
  .footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    padding: 1.5rem 0;
    margin-top: auto;
    color: var(--text-muted);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer-left p {
    margin: 0;
    font-size: 0.875rem;
  }

  .footer-stats {
    display: flex;
    gap: 1rem;
  }

  .stat-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
    background: var(--bg-primary);
    padding: 0.4rem 0.75rem;
    border-radius: 20px;
    border: 1px solid var(--border-color);
  }

  .stat-icon {
    width: 14px;
    height: 14px;
    color: var(--accent-cyan);
  }

  .stat-text {
    font-family: 'JetBrains Mono', monospace;
    color: var(--accent-cyan);
  }

  @media (max-width: 480px) {
    .footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
