---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <p>© {year} Web Toolbox. Built with Astro.</p>
    </div>
    <div class="footer-stats">
      <span class="stat-item" id="visitorStats" title="页面访问统计">
        <span class="stat-text">你已访问 -- 次</span>
      </span>
      <span id="busuanzi_container_site_pv" class="stat-item" style="display:none" title="本站总访问量">
        <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
        <span class="stat-text">PV <span id="busuanzi_value_site_pv"></span></span>
      </span>
      <span id="busuanzi_container_site_uv" class="stat-item" style="display:none" title="本站访客数">
        <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        <span class="stat-text">UV <span id="busuanzi_value_site_uv"></span></span>
      </span>
    </div>
  </div>
</footer>

<script is:inline async src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>

<script>
  function getVisits(): number {
    try {
      return parseInt(localStorage.getItem('tb_visits') || '0', 10);
    } catch { return 0; }
  }

  function getFirstVisit(): string | null {
    try { return localStorage.getItem('tb_first_visit'); } catch { return null; }
  }

  function initCounter() {
    const el = document.getElementById('visitorStats');
    if (!el) return;

    let count = getVisits();
    count++;
    try {
      localStorage.setItem('tb_visits', String(count));
    } catch {}

    const firstVisit = getFirstVisit();
    const today = new Date().toISOString().slice(0, 10);
    if (!firstVisit) {
      try { localStorage.setItem('tb_first_visit', today); } catch {}
    }

    const textEl = el.querySelector('.stat-text')!;
    textEl.textContent = `你已访问 ${count} 次`;
    el.title = firstVisit ? `首次访问: ${firstVisit}` : `首次访问: ${today}`;
  }

  initCounter();
</script>

<style>
  .footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    padding: 1.5rem 0;
    margin-top: auto;
    color: var(--text-muted);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer-left p {
    margin: 0;
    font-size: 0.875rem;
  }

  .footer-stats {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .stat-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
    background: var(--bg-primary);
    padding: 0.4rem 0.75rem;
    border-radius: 20px;
    border: 1px solid var(--border-color);
  }

  .stat-icon {
    width: 14px;
    height: 14px;
    color: var(--accent-cyan);
    flex-shrink: 0;
  }

  .stat-text {
    font-family: 'JetBrains Mono', monospace;
    color: var(--accent-cyan);
    white-space: nowrap;
  }

  @media (max-width: 480px) {
    .footer-inner {
      flex-direction: column;
      text-align: center;
    }

    .footer-stats {
      justify-content: center;
    }
  }
</style>
