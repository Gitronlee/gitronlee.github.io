  }

  .slice-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 0.5rem;
  }

  .slice-card img {
    width: 100px;
    height: auto;
    border-radius: 4px;
  }

  .slice-label {
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .btn-dl-one {
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.7rem;
    cursor: pointer;
    background: var(--bg-tertiary);
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
    font-family: inherit;
