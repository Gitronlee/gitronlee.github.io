<div class="image-slicer" id="slicerRoot">
  <div class="slicer-controls">
    <div class="ctrl-group">
      <label class="upload-btn">
        选择图片
        <input type="file" id="fileInput" accept="image/jpeg,image/png,image/webp" hidden />
      </label>
    </div>
    <div class="ctrl-group">
      <label>列数</label>
      <input type="number" id="colsInput" value="3" min="1" max="20" />
    </div>
    <div class="ctrl-group">
      <label>行数</label>
      <input type="number" id="rowsInput" value="2" min="1" max="20" />
    </div>
    <button class="btn-slice" id="btnSlice" disabled>执行切片</button>
    <button class="btn-reset-grid" id="btnResetGrid">重置网格</button>
    <button class="btn-download-all" id="btnDownloadAll" disabled>下载全部</button>
  </div>

  <div class="slicer-preview" id="previewArea" style="display:none">
    <div class="preview-container" id="previewContainer">
      <img id="previewImg" alt="预览" draggable="false" />
      <canvas id="gridCanvas"></canvas>
    </div>
    <p class="drag-hint">拖拽网格线微调切片边界</p>
  </div>

  <div class="slicer-output" id="outputArea" style="display:none">
    <div class="output-header">切片结果</div>
    <div class="output-grid" id="outputGrid"></div>
  </div>
</div>

<script>
  function loadScript(src: string): Promise<void> {
    return new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = src;
      s.onload = () => resolve();
      s.onerror = () => reject(new Error(`failed to load ${src}`));
      document.head.appendChild(s);
    });
  }

  async function ensureDeps() {
    if (!(window as any).JSZip) {
      await loadScript('https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js');
    }
    if (!(window as any).saveAs) {
      await loadScript('https://cdnjs.cloudflare.com/ajax/libs/FileSaver.js/2.0.5/FileSaver.min.js');
    }
  }

  const fileInput = document.getElementById('fileInput') as HTMLInputElement;
  const colsInput = document.getElementById('colsInput') as HTMLInputElement;
  const rowsInput = document.getElementById('rowsInput') as HTMLInputElement;
  const btnSlice = document.getElementById('btnSlice') as HTMLButtonElement;
  const btnResetGrid = document.getElementById('btnResetGrid') as HTMLButtonElement;
  const btnDownloadAll = document.getElementById('btnDownloadAll') as HTMLButtonElement;
  const previewArea = document.getElementById('previewArea')!;
  const previewImg = document.getElementById('previewImg') as HTMLImageElement;
  const gridCanvas = document.getElementById('gridCanvas') as HTMLCanvasElement;
  const previewContainer = document.getElementById('previewContainer')!;
  const outputArea = document.getElementById('outputArea')!;
  const outputGrid = document.getElementById('outputGrid')!;

  let originalImage: HTMLImageElement | null = null;
  let slices: Array<{ blob: Blob; row: number; col: number }> = [];

  // Grid line positions as fractions 0..1 (divider positions, excluding 0 and 1)
  let colPositions: number[] = [];
  let rowPositions: number[] = [];

  // Drag state
  type DragAxis = 'col' | 'row';
  let dragging: { axis: DragAxis; index: number } | null = null;
  const DRAG_THRESHOLD = 10; // px threshold to grab a line
  const MIN_GAP = 0.03;      // minimum gap between adjacent lines (fraction)

  function normalizeInputs() {
    let cols = parseInt(colsInput.value) || 1;
    let rows = parseInt(rowsInput.value) || 1;
    if (cols < 1) cols = 1;
    if (cols > 20) cols = 20;
    if (rows < 1) rows = 1;
    if (rows > 20) rows = 20;
    colsInput.value = String(cols);
    rowsInput.value = String(rows);
    return { cols, rows };
  }

  // Recalculate positions from equal divisions
  function resetPositions() {
    const { cols, rows } = normalizeInputs();
    colPositions = [];
    for (let i = 1; i < cols; i++) {
      colPositions.push(i / cols);
    }
    rowPositions = [];
    for (let i = 1; i < rows; i++) {
      rowPositions.push(i / rows);
    }
  }

  // Get canvas dimensions and offset relative to image
  function getCanvasLayout() {
    const imgRect = previewImg.getBoundingClientRect();
    const containerRect = previewContainer.getBoundingClientRect();
    return {
      offsetX: imgRect.left - containerRect.left,
      offsetY: imgRect.top - containerRect.top,
      w: imgRect.width,
      h: imgRect.height,
    };
  }

  function drawGrid() {
    if (!originalImage || !previewImg.complete) return;

    const { offsetX, offsetY, w, h } = getCanvasLayout();

    gridCanvas.style.left = offsetX + 'px';
    gridCanvas.style.top = offsetY + 'px';
    gridCanvas.width = Math.max(1, w);
    gridCanvas.height = Math.max(1, h);

    const ctx = gridCanvas.getContext('2d')!;
    ctx.clearRect(0, 0, w, h);

    // Draw grid lines
    ctx.strokeStyle = dragging ? '#f97316' : '#ef4444';
    ctx.lineWidth = 2.5;
    ctx.setLineDash([8, 5]);

    for (const pos of colPositions) {
      const x = pos * w;
      ctx.beginPath();
      ctx.moveTo(x, 0);
      ctx.lineTo(x, h);
      ctx.stroke();
    }
    for (const pos of rowPositions) {
      const y = pos * h;
      ctx.beginPath();
      ctx.moveTo(0, y);
      ctx.lineTo(w, y);
      ctx.stroke();
    }

    // Draw drag handles (circles at midpoints of each line)
    ctx.setLineDash([]);
    const handleR = 6;
    const midH = h / 2;
    const midW = w / 2;

    colPositions.forEach((pos, i) => {
      const x = pos * w;
      ctx.beginPath();
      ctx.arc(x, midH, handleR, 0, Math.PI * 2);
      ctx.fillStyle = dragging?.axis === 'col' && dragging.index === i ? '#f97316' : '#ef4444';
      ctx.fill();
      ctx.strokeStyle = '#fff';
      ctx.lineWidth = 1.5;
      ctx.stroke();
    });

    rowPositions.forEach((pos, i) => {
      const y = pos * h;
      ctx.beginPath();
      ctx.arc(midW, y, handleR, 0, Math.PI * 2);
      ctx.fillStyle = dragging?.axis === 'row' && dragging.index === i ? '#f97316' : '#ef4444';
      ctx.fill();
      ctx.strokeStyle = '#fff';
      ctx.lineWidth = 1.5;
      ctx.stroke();
    });
  }

  // Hit test: find nearest line within threshold
  function findNearestLine(clientX: number, clientY: number): { axis: DragAxis; index: number } | null {
    const rect = gridCanvas.getBoundingClientRect();
    const mx = clientX - rect.left;
    const my = clientY - rect.top;
    const { w, h } = getCanvasLayout();

    let best: { axis: DragAxis; index: number; dist: number } | null = null;

    colPositions.forEach((pos, i) => {
      const dist = Math.abs(mx - pos * w);
      if (dist < DRAG_THRESHOLD && my >= 0 && my <= h) {
        if (!best || dist < best.dist) best = { axis: 'col', index: i, dist };
      }
    });

    rowPositions.forEach((pos, i) => {
      const dist = Math.abs(my - pos * h);
      if (dist < DRAG_THRESHOLD && mx >= 0 && mx <= w) {
        if (!best || dist < best.dist) best = { axis: 'row', index: i, dist };
      }
    });

    return best ? { axis: best.axis, index: best.index } : null;
  }

  // Clamp a line position between neighbors
  function clampPosition(axis: DragAxis, index: number, value: number): number {
    const positions = axis === 'col' ? colPositions : rowPositions;
    const min = index > 0 ? positions[index - 1] + MIN_GAP : MIN_GAP;
    const max = index < positions.length - 1 ? positions[index + 1] - MIN_GAP : 1 - MIN_GAP;
    return Math.max(min, Math.min(max, value));
  }

  // --- Event Handlers ---

  gridCanvas.addEventListener('mousedown', (e) => {
    const nearest = findNearestLine(e.clientX, e.clientY);
    if (!nearest) return;
    e.preventDefault();
    dragging = nearest;
    (gridCanvas.style as any).cursor =
      nearest.axis === 'col' ? 'col-resize' : 'row-resize';
    drawGrid();
  });

  window.addEventListener('mousemove', (e) => {
    if (!gridCanvas.isConnected) return;

    if (dragging) {
      const rect = gridCanvas.getBoundingClientRect();
      const { w, h } = getCanvasLayout();
      const frac = dragging.axis === 'col'
        ? (e.clientX - rect.left) / w
        : (e.clientY - rect.top) / h;
      const clamped = clampPosition(dragging.axis, dragging.index, frac);

      if (dragging.axis === 'col') {
        colPositions[dragging.index] = clamped;
      } else {
        rowPositions[dragging.index] = clamped;
      }
      drawGrid();
    } else {
      const nearest = findNearestLine(e.clientX, e.clientY);
      (gridCanvas.style as any).cursor = nearest
        ? (nearest.axis === 'col' ? 'col-resize' : 'row-resize')
        : 'default';
    }
  });

  window.addEventListener('mouseup', () => {
    if (dragging) {
      dragging = null;
      (gridCanvas.style as any).cursor = 'default';
      drawGrid();
    }
  });

  // Touch support
  gridCanvas.addEventListener('touchstart', (e) => {
    const touch = e.touches[0];
    const nearest = findNearestLine(touch.clientX, touch.clientY);
    if (!nearest) return;
    e.preventDefault();
    dragging = nearest;
    drawGrid();
  }, { passive: false });

  window.addEventListener('touchmove', (e) => {
    if (!dragging || !gridCanvas.isConnected) return;
    e.preventDefault();
    const touch = e.touches[0];
    const rect = gridCanvas.getBoundingClientRect();
    const { w, h } = getCanvasLayout();
    const frac = dragging.axis === 'col'
      ? (touch.clientX - rect.left) / w
      : (touch.clientY - rect.top) / h;
    const clamped = clampPosition(dragging.axis, dragging.index, frac);

    if (dragging.axis === 'col') {
      colPositions[dragging.index] = clamped;
    } else {
      rowPositions[dragging.index] = clamped;
    }
    drawGrid();
  }, { passive: false });

  window.addEventListener('touchend', () => {
    if (dragging) {
      dragging = null;
      drawGrid();
    }
  });

  // --- Upload / Controls ---

  fileInput.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (!file) return;

    if (!file.type.startsWith('image/')) {
      alert('请上传图片文件（jpg / png / webp）');
      fileInput.value = '';
      return;
    }

    const reader = new FileReader();
    reader.onload = (e) => {
      previewImg.src = e.target?.result as string;
      previewImg.onload = () => {
        originalImage = previewImg;
        previewArea.style.display = '';
        outputArea.style.display = 'none';
        slices = [];
        resetPositions();
        btnSlice.disabled = false;
        btnDownloadAll.disabled = true;

        requestAnimationFrame(() => {
          requestAnimationFrame(drawGrid);
        });
      };
    };
    reader.readAsDataURL(file);
  });

  colsInput.addEventListener('input', () => { resetPositions(); drawGrid(); });
  rowsInput.addEventListener('input', () => { resetPositions(); drawGrid(); });
  window.addEventListener('resize', drawGrid);

  btnResetGrid.addEventListener('click', () => {
    resetPositions();
    drawGrid();
  });

  btnSlice.addEventListener('click', () => {
    if (!originalImage) return;

    const imgW = originalImage.naturalWidth;
    const imgH = originalImage.naturalHeight;

    // Build pixel coords: [0, ...colPositions*imgW, imgW] and [0, ...rowPositions*imgH, imgH]
    const colPx = [0, ...colPositions.map(p => p * imgW), imgW];
    const rowPx = [0, ...rowPositions.map(p => p * imgH), imgH];

    const canvas = document.createElement('canvas');
    const ctx = canvas.getContext('2d')!;
    slices = [];
    outputGrid.innerHTML = '';

    for (let r = 0; r < rowPx.length - 1; r++) {
      for (let c = 0; c < colPx.length - 1; c++) {
        const sx = colPx[c];
        const sy = rowPx[r];
        const sw = colPx[c + 1] - sx;
        const sh = rowPx[r + 1] - sy;

        canvas.width = Math.ceil(sw);
        canvas.height = Math.ceil(sh);
        ctx.drawImage(originalImage, sx, sy, sw, sh, 0, 0, sw, sh);

        canvas.toBlob((blob) => {
          if (!blob) return;
          slices.push({ blob, row: r + 1, col: c + 1 });

          const url = URL.createObjectURL(blob);
          const card = document.createElement('div');
          card.className = 'slice-card';
          card.innerHTML = `
            <img src="${url}" alt="行${r + 1}-列${c + 1}" />
            <span class="slice-label">行${r + 1}-列${c + 1}</span>
            <button class="btn-dl-one">下载</button>
          `;
          card.querySelector('.btn-dl-one')!.addEventListener('click', async (e) => {
            e.stopPropagation();
            await ensureDeps();
            (window as any).saveAs(blob, `piece_r${r + 1}_c${c + 1}.png`);
          });
          outputGrid.appendChild(card);

          if (slices.length === (colPx.length - 1) * (rowPx.length - 1)) {
            btnDownloadAll.disabled = false;
          }
        }, 'image/png');
      }
    }

    outputArea.style.display = '';
  });

  btnDownloadAll.addEventListener('click', async () => {
    if (slices.length === 0) return;
    await ensureDeps();

    const JSZip = (window as any).JSZip;
    const zip = new JSZip();
    slices.forEach(({ blob, row, col }) => {
      zip.file(`piece_r${row}_c${col}.png`, blob);
    });

    const zipBlob = await zip.generateAsync({ type: 'blob' });
    (window as any).saveAs(zipBlob, 'image_slices.zip');
  });
</script>

<style>
  .image-slicer {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .slicer-controls {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 0.75rem;
  }

  .ctrl-group {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .ctrl-group label {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .ctrl-group input[type="number"] {
    width: 70px;
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    padding: 0.5rem 0.6rem;
    border-radius: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9375rem;
    text-align: center;
  }

  .ctrl-group input:focus {
    border-color: var(--accent-blue);
    outline: none;
  }

  .upload-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 1.25rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    background: var(--accent-blue);
    color: #000;
    border: none;
    transition: var(--transition);
  }

  .upload-btn:hover {
    opacity: 0.9;
  }

  .btn-slice {
    padding: 0.55rem 1.5rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    background: var(--accent-purple);
    color: #fff;
    border: none;
    transition: var(--transition);
  }

  .btn-slice:hover:not(:disabled) {
    opacity: 0.9;
  }

  .btn-slice:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .btn-reset-grid {
    padding: 0.55rem 1rem;
    border-radius: 8px;
    font-size: 0.8125rem;
    cursor: pointer;
    background: var(--bg-tertiary);
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
    font-family: inherit;
    transition: var(--transition);
  }

  .btn-reset-grid:hover {
    border-color: var(--accent-blue);
    color: var(--text-primary);
  }

  .btn-download-all {
    padding: 0.55rem 1.5rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    background: var(--accent-green);
    color: #000;
    border: none;
    transition: var(--transition);
  }

  .btn-download-all:hover:not(:disabled) {
    background: #00e676;
  }

  .btn-download-all:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .slicer-preview {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    overflow: auto;
  }

  .preview-container {
    position: relative;
    display: inline-block;
    line-height: 0;
  }

  .preview-container img {
    max-width: 100%;
    max-height: 500px;
    display: block;
    border-radius: 4px;
    user-select: none;
    -webkit-user-drag: none;
  }

  .preview-container canvas {
    position: absolute;
    top: 0;
    left: 0;
  }

  .drag-hint {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin: 0;
  }

  .slicer-output {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .output-header {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 1rem;
  }

  .output-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .slice-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 0.5rem;
  }

  .slice-card img {
    width: 100px;
    height: auto;
    border-radius: 4px;
  }

  .slice-label {
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .btn-dl-one {
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.7rem;
    cursor: pointer;
    background: var(--bg-tertiary);
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
    font-family: inherit;
    transition: var(--transition);
  }

  .btn-dl-one:hover {
    border-color: var(--accent-blue);
    color: var(--text-primary);
  }
</style>
