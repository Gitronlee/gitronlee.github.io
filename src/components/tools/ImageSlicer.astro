    border-color: var(--accent-blue);
    outline: none;
  }

  .upload-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 1.25rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    background: var(--accent-blue);
    color: #000;
    border: none;
    transition: var(--transition);
  }

  .upload-btn:hover {
    opacity: 0.9;
  }

  .btn-slice {
    padding: 0.55rem 1.5rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    background: var(--accent-purple);
    color: #fff;
    border: none;
    transition: var(--transition);
  }

  .btn-slice:hover:not(:disabled) {
    opacity: 0.9;
  }

  .btn-slice:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .btn-download-all {
    padding: 0.55rem 1.5rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    background: var(--accent-green);
    color: #000;
    border: none;
    transition: var(--transition);
  }

  .btn-download-all:hover:not(:disabled) {
    background: #00e676;
  }

  .btn-download-all:disabled {
    opacity: 0.4;
