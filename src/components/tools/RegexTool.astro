<div class="regex-tool">
  <div class="input-group">
    <label>正则表达式</label>
    <div class="regex-input-row">
      <span class="delimiter">/</span>
      <input type="text" id="regexInput" placeholder="输入正则表达式..." />
      <span class="delimiter">/</span>
      <input type="text" id="flagsInput" placeholder="gi" class="flags-input" />
    </div>
  </div>
  
  <div class="input-group">
    <label>测试文本</label>
    <textarea id="testText" placeholder="输入要测试的文本..." rows="6"></textarea>
  </div>
  
  <div class="input-group">
    <label>匹配结果</label>
    <div id="result" class="result"></div>
  </div>
</div>

<script>
  const regexInput = document.getElementById('regexInput');
  const flagsInput = document.getElementById('flagsInput');
  const testText = document.getElementById('testText');
  const result = document.getElementById('result');

  function runTest() {
    const pattern = regexInput?.value;
    const flags = flagsInput?.value || '';
    const text = testText?.value || '';
    const resultEl = result;

    if (!pattern || !text) {
      resultEl.innerHTML = '<span class="empty">等待输入...</span>';
      return;
    }

    try {
      const regex = new RegExp(pattern, flags);
      const matches = text.match(regex);
      
      let highlighted = text;
      if (flags.includes('g')) {
        let match;
        const globalRegex = new RegExp(pattern, flags);
        const replacements: Array<{ start: number; end: number; text: string }> = [];
        while ((match = globalRegex.exec(text)) !== null) {
          replacements.push({
            start: match.index,
            end: match.index + match[0].length,
            text: match[0]
          });
        }
        
        let resultText = '';
        let lastIndex = 0;
        for (const rep of replacements) {
          resultText += text.slice(lastIndex, rep.start);
          resultText += `<mark class="match">${escapeHtml(rep.text)}</mark>`;
          lastIndex = rep.end;
        }
        resultText += text.slice(lastIndex);
        highlighted = resultText;
      } else if (matches) {
        const idx = text.indexOf(matches[0]);
        highlighted = 
          escapeHtml(text.slice(0, idx)) +
          `<mark class="match">${escapeHtml(matches[0])}</mark>` +
          escapeHtml(text.slice(idx + matches[0].length));
      }
      
      resultEl.innerHTML = `<div class="highlighted-text">${highlighted}</div>`;
      
      if (matches) {
        resultEl.innerHTML += `<div class="match-info">找到 ${matches.length} 个匹配</div>`;
      }
    } catch (e: any) {
      resultEl.innerHTML = `<span class="error">错误: ${escapeHtml(e.message)}</span>`;
    }
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  regexInput?.addEventListener('input', runTest);
  flagsInput?.addEventListener('input', runTest);
  testText?.addEventListener('input', runTest);
</script>

<style>
  .regex-tool {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  
  .input-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .input-group label {
    font-weight: 500;
    color: var(--text-secondary);
    font-size: 0.875rem;
  }
  
  .regex-input-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--bg-primary);
    padding: 0.5rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
  }
  
  .regex-input-row input {
    background: transparent;
    border: none;
    color: var(--text-primary);
    font-family: 'JetBrains Mono', monospace;
    font-size: 1rem;
    flex: 1;
    outline: none;
  }
  
  .delimiter {
    color: var(--accent-purple);
    font-weight: bold;
  }
  
  .flags-input {
    max-width: 60px;
    color: var(--accent-cyan) !important;
  }
  
  textarea, input[type="text"] {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    padding: 0.75rem;
    border-radius: 8px;
    font-family: 'JetBrains Mono', monospace;
    resize: vertical;
  }
  
  textarea:focus, input:focus {
    border-color: var(--accent-blue);
    outline: none;
  }
  
  .result {
    background: var(--bg-primary);
    border-radius: 8px;
    padding: 1rem;
    min-height: 80px;
    border: 1px solid var(--border-color);
  }
  
  .empty {
    color: var(--text-muted);
  }
  
  .error {
    color: #ef4444;
  }
  
  .highlighted-text {
    font-family: 'JetBrains Mono', monospace;
    line-height: 1.8;
    white-space: pre-wrap;
    word-break: break-all;
  }
  
  .match {
    background: rgba(59, 130, 246, 0.3);
    color: var(--accent-blue);
    padding: 0 2px;
    border-radius: 2px;
  }
  
  .match-info {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border-color);
    color: var(--accent-green);
    font-size: 0.875rem;
  }
</style>
