    border-radius: 6px;
    border: 1px solid var(--border-color);
  }

  .base-section {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .base-label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .base-toggle {
    display: flex;
    gap: 0;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    overflow: hidden;
    width: fit-content;
  }

  .base-option {
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
    cursor: pointer;
    background: var(--bg-primary);
    color: var(--text-muted);
    border: none;
    font-family: inherit;
    transition: var(--transition);
  }

  .base-option:first-child {
    border-right: 1px solid var(--border-color);
  }

  .base-option.active {
    background: var(--accent-blue);
    color: #000;
    font-weight: 600;
  }

  .base-custom-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .base-custom-row input {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    padding: 0.65rem 0.75rem;
    border-radius: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9375rem;
