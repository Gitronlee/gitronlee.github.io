    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9375rem;
    width: 200px;
  }

  .base-custom-row input:focus {
    border-color: var(--accent-blue);
    outline: none;
  }

  .base-hint {
    font-size: 0.75rem;
    color: var(--text-muted);
  }
</style>
