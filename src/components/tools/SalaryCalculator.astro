<div class="salary-calc" id="salaryRoot">
  <div class="calc-inputs">
    <div class="input-group">
      <label>税前月薪 (元)</label>
      <input type="number" id="grossSalary" placeholder="输入税前月薪" value="15000" />
    </div>
    <div class="input-group">
      <label>社保公积金城市</label>
      <select id="citySelect"></select>
    </div>
    <div class="input-group">
      <label>公积金比例</label>
      <select id="fundRate">
        <option value="5">5%</option>
        <option value="7" selected>7%</option>
        <option value="8">8%</option>
        <option value="10">10%</option>
        <option value="12">12%</option>
      </select>
    </div>
    <div class="input-group">
      <label>专项附加扣除 (元/月)</label>
      <input type="number" id="deductions" placeholder="租房、赡养老人等" value="3000" />
    </div>
    <div class="input-group">
      <label>年终奖 (元)</label>
      <input type="number" id="annualBonus" placeholder="年终奖金额" value="0" />
    </div>
    <div class="input-group">
      <label>年终奖计税方式</label>
      <select id="bonusTaxMethod">
        <option value="separate" selected>单独计税</option>
        <option value="combine">并入综合所得</option>
      </select>
    </div>
  </div>

  <div class="base-section">
    <label class="base-label">社保公积金缴费基数</label>
    <div class="base-toggle">
      <button class="base-option active" id="baseFull">工资全额</button>
      <button class="base-option" id="baseCustom">自定义基数</button>
    </div>
    <div class="base-custom-row" id="baseCustomRow" style="display:none">
      <input type="number" id="customBase" placeholder="自定义缴费基数" value="15000" />
      <span class="base-hint" id="baseHint"></span>
    </div>
  </div>

  <div class="calc-result" id="calcResult">
    <div class="result-main">
      <div class="result-item highlight">
        <span class="result-label">税后到手</span>
        <span class="result-value accent" id="netPay">--</span>
      </div>
    </div>

    <div class="result-breakdown">
      <div class="breakdown-item">
        <span>社保个人缴纳</span>
        <span class="val" id="siAmount">--</span>
      </div>
      <div class="breakdown-item">
        <span>公积金个人缴纳</span>
        <span class="val" id="hfAmount">--</span>
      </div>
      <div class="breakdown-item">
        <span>公积金账户增量 (双边)</span>
        <span class="val" id="hfTotal">--</span>
      </div>
      <div class="breakdown-item">
        <span>应纳税所得额</span>
        <span class="val" id="taxableIncome">--</span>
      </div>
      <div class="breakdown-item">
        <span>个人所得税</span>
        <span class="val" id="taxAmount">--</span>
      </div>
      <div class="breakdown-item">
        <span>年终奖个税</span>
        <span class="val" id="bonusTax">--</span>
      </div>
    </div>
  </div>

  <div class="annual-summary" id="annualSummary">
    <div class="summary-title">年度统计</div>
    <div class="summary-grid">
      <div class="summary-item">
        <span class="summary-label">年薪总额 (税前)</span>
        <span class="summary-value" id="annualGross">--</span>
      </div>
      <div class="summary-item">
        <span class="summary-label">年薪到手 (税后)</span>
        <span class="summary-value accent" id="annualNet">--</span>
      </div>
      <div class="summary-item">
        <span class="summary-label">年终奖 (税前)</span>
        <span class="summary-value" id="annualBonusDisplay">--</span>
      </div>
      <div class="summary-item">
        <span class="summary-label">年终奖到手 (税后)</span>
        <span class="summary-value" id="annualBonusNet">--</span>
      </div>
      <div class="summary-item">
        <span class="summary-label">年总收入 (税后)</span>
        <span class="summary-value highlight" id="totalAnnualNet">--</span>
      </div>
      <div class="summary-item">
        <span class="summary-label">年公积金账户增量</span>
        <span class="summary-value" id="annualHfTotal">--</span>
      </div>
      <div class="summary-item">
        <span class="summary-label">年社保个人缴纳</span>
        <span class="summary-value" id="annualSi">--</span>
      </div>
      <div class="summary-item">
        <span class="summary-label">年个税总额</span>
        <span class="summary-value" id="annualTaxTotal">--</span>
      </div>
    </div>
  </div>

  <div class="calc-note">
    计算基于现行个税累进税率，社保比例按个人缴费标准（养老8% + 医疗2% + 失业0.5%），公积金按所选比例。
    社保基数上限因城市而异，超出部分不缴纳社保公积金。
  </div>
</div>

<script>
  interface CityConfig {
    label: string;
    siCap: number;   // 社保基数上限
    hfCap: number;   // 公积金基数上限
  }

  const cities: CityConfig[] = [
    { label: '北京 (上限 35811/35811)', siCap: 35811, hfCap: 35811 },
    { label: '上海 (上限 37302/36921)', siCap: 37302, hfCap: 36921 },
    { label: '广州 (上限 27549/39828)', siCap: 27549, hfCap: 39828 },
    { label: '深圳 (上限 27549/41190)', siCap: 27549, hfCap: 41190 },
    { label: '杭州 (上限 40694/40694)', siCap: 40694, hfCap: 40694 },
    { label: '成都 (上限 22938/31378)', siCap: 22938, hfCap: 31378 },
    { label: '武汉 (上限 22488/34560)', siCap: 22488, hfCap: 34560 },
    { label: '南京 (上限 24762/41400)', siCap: 24762, hfCap: 41400 },
    { label: '不限上限', siCap: Infinity, hfCap: Infinity },
  ];

  const citySelect = document.getElementById('citySelect') as HTMLSelectElement;
  citySelect.innerHTML = cities.map((c, i) =>
    `<option value="${i}" ${i === 0 ? 'selected' : ''}>${c.label}</option>`
  ).join('');

  const grossInput = document.getElementById('grossSalary') as HTMLInputElement;
  const fundSelect = document.getElementById('fundRate') as HTMLSelectElement;
  const dedInput = document.getElementById('deductions') as HTMLInputElement;
  const bonusInput = document.getElementById('annualBonus') as HTMLInputElement;
  const bonusMethodSelect = document.getElementById('bonusTaxMethod') as HTMLSelectElement;
  const baseFullBtn = document.getElementById('baseFull')!;
  const baseCustomBtn = document.getElementById('baseCustom')!;
  const baseCustomRow = document.getElementById('baseCustomRow')!;
  const customBaseInput = document.getElementById('customBase') as HTMLInputElement;
  const baseHint = document.getElementById('baseHint')!;

  let baseMode: 'full' | 'custom' = 'full';

  function setBaseMode(mode: 'full' | 'custom') {
    baseMode = mode;
    baseFullBtn.classList.toggle('active', mode === 'full');
    baseCustomBtn.classList.toggle('active', mode === 'custom');
    baseCustomRow.style.display = mode === 'custom' ? 'flex' : 'none';
    recalc();
  }

  baseFullBtn.addEventListener('click', () => setBaseMode('full'));
  baseCustomBtn.addEventListener('click', () => setBaseMode('custom'));

  const netPayEl = document.getElementById('netPay')!;
  const siAmtEl = document.getElementById('siAmount')!;
  const hfAmtEl = document.getElementById('hfAmount')!;
  const hfTotalEl = document.getElementById('hfTotal')!;
  const taxableEl = document.getElementById('taxableIncome')!;
  const taxEl = document.getElementById('taxAmount')!;
  const bonusTaxEl = document.getElementById('bonusTax')!;

  // Annual summary elements
  const annualGrossEl = document.getElementById('annualGross')!;
  const annualNetEl = document.getElementById('annualNet')!;
  const annualBonusDisplayEl = document.getElementById('annualBonusDisplay')!;
  const annualBonusNetEl = document.getElementById('annualBonusNet')!;
  const totalAnnualNetEl = document.getElementById('totalAnnualNet')!;
  const annualHfTotalEl = document.getElementById('annualHfTotal')!;
  const annualSiEl = document.getElementById('annualSi')!;
  const annualTaxTotalEl = document.getElementById('annualTaxTotal')!;

  // Tax brackets: [upper_bound, rate, quick_deduction]
  const brackets: [number, number, number][] = [
    [36000, 0.03, 0],
    [144000, 0.10, 2520],
    [300000, 0.20, 16920],
    [420000, 0.25, 31920],
    [660000, 0.30, 52920],
    [960000, 0.35, 85920],
    [Infinity, 0.45, 181920],
  ];

  function calcAnnualTax(annualTaxable: number): number {
    if (annualTaxable <= 0) return 0;
    for (const [upper, rate, quick] of brackets) {
      if (annualTaxable <= upper) {
        return annualTaxable * rate - quick;
      }
    }
    return 0;
  }

  // Annual bonus tax calculation (separate method: divide by 12, find bracket)
  function calcBonusTaxSeparate(bonus: number): number {
    if (bonus <= 0) return 0;
    const monthly = bonus / 12;
    for (const [upper, rate, quick] of brackets) {
      if (monthly <= upper) {
        return bonus * rate - quick;
      }
    }
    return 0;
  }

  function recalc() {
    const gross = parseFloat(grossInput.value) || 0;
    const city = cities[parseInt(citySelect.value) || 0];
    const fundPct = parseFloat(fundSelect.value) / 100;
    const ded = parseFloat(dedInput.value) || 0;
    const bonus = parseFloat(bonusInput.value) || 0;
    const bonusMethod = bonusMethodSelect.value;

    let siBase: number;
    let hfBase: number;

    if (baseMode === 'custom') {
      const custom = parseFloat(customBaseInput.value) || 0;
      siBase = Math.min(custom, city.siCap);
      hfBase = Math.min(custom, city.hfCap);
      baseHint.textContent = city.siCap === Infinity
        ? '无上限限制'
        : `上限 ${city.siCap.toLocaleString()}，实缴基数 ${siBase.toLocaleString()}`;
    } else {
      siBase = Math.min(gross, city.siCap);
      hfBase = Math.min(gross, city.hfCap);
    }

    const siAmount = Math.round(siBase * 0.105);  // 10.5%
    const hfAmount = Math.round(hfBase * fundPct);
    const hfTotal = hfAmount * 2; // 个人 + 公司

    let monthlyTaxable: number;
    let annualTax: number;
    let bonusTax = 0;

    if (bonusMethod === 'combine') {
      // 年终奖并入综合所得
      monthlyTaxable = gross - siAmount - hfAmount - 5000 - ded;
      const annualComprehensive = monthlyTaxable * 12 + bonus;
      annualTax = calcAnnualTax(annualComprehensive);
    } else {
      // 年终奖单独计税
      monthlyTaxable = gross - siAmount - hfAmount - 5000 - ded;
      annualTax = calcAnnualTax(monthlyTaxable * 12);
      bonusTax = calcBonusTaxSeparate(bonus);
    }

    const monthlyTax = Math.round(annualTax / 12);
    const net = gross - siAmount - hfAmount - monthlyTax;

    // Monthly display
    netPayEl.textContent = net.toLocaleString() + ' 元';
    siAmtEl.textContent = siAmount.toLocaleString() + ' 元';
    hfAmtEl.textContent = hfAmount.toLocaleString() + ' 元';
    hfTotalEl.textContent = hfTotal.toLocaleString() + ' 元';
    taxableEl.textContent = (monthlyTaxable > 0 ? monthlyTaxable.toLocaleString() : '0') + ' 元';
    taxEl.textContent = monthlyTax.toLocaleString() + ' 元';
    bonusTaxEl.textContent = bonusTax.toLocaleString() + ' 元';

    // Annual summary
    const annualGrossSalary = gross * 12;
    const annualNetSalary = net * 12;
    const annualSi = siAmount * 12;
    const annualHfTotal = hfTotal * 12;
    const bonusNet = bonus - bonusTax;
    const totalNet = annualNetSalary + bonusNet;
    const totalTax = annualTax + bonusTax;

    annualGrossEl.textContent = annualGrossSalary.toLocaleString() + ' 元';
    annualNetEl.textContent = annualNetSalary.toLocaleString() + ' 元';
    annualBonusDisplayEl.textContent = bonus.toLocaleString() + ' 元';
    annualBonusNetEl.textContent = bonusNet.toLocaleString() + ' 元';
    totalAnnualNetEl.textContent = totalNet.toLocaleString() + ' 元';
    annualHfTotalEl.textContent = annualHfTotal.toLocaleString() + ' 元';
    annualSiEl.textContent = annualSi.toLocaleString() + ' 元';
    annualTaxTotalEl.textContent = totalTax.toLocaleString() + ' 元';
  }

  grossInput.addEventListener('input', recalc);
  citySelect.addEventListener('change', recalc);
  fundSelect.addEventListener('change', recalc);
  dedInput.addEventListener('input', recalc);
  customBaseInput.addEventListener('input', recalc);
  bonusInput.addEventListener('input', recalc);
  bonusMethodSelect.addEventListener('change', recalc);

  recalc();
</script>

<style>
