<div class="salary-calc" id="salaryRoot">
  <div class="calc-inputs">
    <div class="input-group">
      <label>税前月薪 (元)</label>
      <input type="number" id="grossSalary" placeholder="输入税前月薪" value="15000" />
    </div>
    <div class="input-group">
      <label>社保公积金城市</label>
      <select id="citySelect"></select>
    </div>
    <div class="input-group">
      <label>公积金比例</label>
      <select id="fundRate">
        <option value="5">5%</option>
        <option value="7" selected>7%</option>
        <option value="8">8%</option>
        <option value="10">10%</option>
        <option value="12">12%</option>
      </select>
    </div>
    <div class="input-group">
      <label>专项附加扣除 (元/月)</label>
      <input type="number" id="deductions" placeholder="租房、赡养老人等" value="3000" />
    </div>
  </div>

  <div class="base-section">
    <label class="base-label">社保公积金缴费基数</label>
    <div class="base-toggle">
      <button class="base-option active" id="baseFull">工资全额</button>
      <button class="base-option" id="baseCustom">自定义基数</button>
    </div>
    <div class="base-custom-row" id="baseCustomRow" style="display:none">
      <input type="number" id="customBase" placeholder="自定义缴费基数" value="15000" />
      <span class="base-hint" id="baseHint"></span>
    </div>
  </div>

  <div class="calc-result" id="calcResult">
    <div class="result-main">
      <div class="result-item highlight">
        <span class="result-label">税后到手</span>
        <span class="result-value accent" id="netPay">--</span>
      </div>
    </div>

    <div class="result-breakdown">
      <div class="breakdown-item">
        <span>社保个人缴纳</span>
        <span class="val" id="siAmount">--</span>
      </div>
      <div class="breakdown-item">
        <span>公积金个人缴纳</span>
        <span class="val" id="hfAmount">--</span>
      </div>
      <div class="breakdown-item">
        <span>应纳税所得额</span>
        <span class="val" id="taxableIncome">--</span>
      </div>
      <div class="breakdown-item">
        <span>个人所得税</span>
        <span class="val" id="taxAmount">--</span>
      </div>
    </div>
  </div>

  <div class="calc-note">
    计算基于现行个税累进税率，社保比例按个人缴费标准（养老8% + 医疗2% + 失业0.5%），公积金按所选比例。
    社保基数上限因城市而异，超出部分不缴纳社保公积金。
  </div>
</div>

<script>
  interface CityConfig {
    label: string;
    siCap: number;   // 社保基数上限
    hfCap: number;   // 公积金基数上限
  }

  const cities: CityConfig[] = [
    { label: '北京 (上限 35283)', siCap: 35283, hfCap: 35283 },
    { label: '上海 (上限 36549)', siCap: 36549, hfCap: 36549 },
    { label: '广州 (上限 29979)', siCap: 29979, hfCap: 39579 },
    { label: '深圳 (上限 41190)', siCap: 41190, hfCap: 41190 },
    { label: '杭州 (上限 24060)', siCap: 24060, hfCap: 24060 },
    { label: '成都 (上限 22555)', siCap: 22555, hfCap: 22555 },
    { label: '武汉 (上限 21120)', siCap: 21120, hfCap: 21120 },
    { label: '南京 (上限 24396)', siCap: 24396, hfCap: 24396 },
    { label: '不限上限', siCap: Infinity, hfCap: Infinity },
  ];

  const citySelect = document.getElementById('citySelect') as HTMLSelectElement;
  citySelect.innerHTML = cities.map((c, i) =>
    `<option value="${i}" ${i === 0 ? 'selected' : ''}>${c.label}</option>`
  ).join('');

  const grossInput = document.getElementById('grossSalary') as HTMLInputElement;
  const fundSelect = document.getElementById('fundRate') as HTMLSelectElement;
  const dedInput = document.getElementById('deductions') as HTMLInputElement;
  const baseFullBtn = document.getElementById('baseFull')!;
  const baseCustomBtn = document.getElementById('baseCustom')!;
  const baseCustomRow = document.getElementById('baseCustomRow')!;
  const customBaseInput = document.getElementById('customBase') as HTMLInputElement;
  const baseHint = document.getElementById('baseHint')!;

  let baseMode: 'full' | 'custom' = 'full';

  function setBaseMode(mode: 'full' | 'custom') {
    baseMode = mode;
    baseFullBtn.classList.toggle('active', mode === 'full');
    baseCustomBtn.classList.toggle('active', mode === 'custom');
    baseCustomRow.style.display = mode === 'custom' ? 'flex' : 'none';
    recalc();
  }

  baseFullBtn.addEventListener('click', () => setBaseMode('full'));
  baseCustomBtn.addEventListener('click', () => setBaseMode('custom'));

  const netPayEl = document.getElementById('netPay')!;
  const siAmtEl = document.getElementById('siAmount')!;
  const hfAmtEl = document.getElementById('hfAmount')!;
  const taxableEl = document.getElementById('taxableIncome')!;
  const taxEl = document.getElementById('taxAmount')!;

  // Tax brackets: [upper_bound, rate, quick_deduction]
  const brackets: [number, number, number][] = [
    [36000, 0.03, 0],
    [144000, 0.10, 2520],
    [300000, 0.20, 16920],
    [420000, 0.25, 31920],
    [660000, 0.30, 52920],
    [960000, 0.35, 85920],
    [Infinity, 0.45, 181920],
  ];

  function calcAnnualTax(annualTaxable: number): number {
    if (annualTaxable <= 0) return 0;
    for (const [upper, rate, quick] of brackets) {
      if (annualTaxable <= upper) {
        return annualTaxable * rate - quick;
      }
    }
    return 0;
  }

  function recalc() {
    const gross = parseFloat(grossInput.value) || 0;
    const city = cities[parseInt(citySelect.value) || 0];
    const fundPct = parseFloat(fundSelect.value) / 100;
    const ded = parseFloat(dedInput.value) || 0;

    let siBase: number;
    let hfBase: number;

    if (baseMode === 'custom') {
      const custom = parseFloat(customBaseInput.value) || 0;
      siBase = Math.min(custom, city.siCap);
      hfBase = Math.min(custom, city.hfCap);
      baseHint.textContent = city.siCap === Infinity
        ? '无上限限制'
        : `上限 ${city.siCap.toLocaleString()}，实缴基数 ${siBase.toLocaleString()}`;
    } else {
      siBase = Math.min(gross, city.siCap);
      hfBase = Math.min(gross, city.hfCap);
    }

    const siAmount = Math.round(siBase * 0.105);  // 10.5%
    const hfAmount = Math.round(hfBase * fundPct);

    const monthlyTaxable = gross - siAmount - hfAmount - 5000 - ded;
    const annualTax = calcAnnualTax(monthlyTaxable * 12);
    const monthlyTax = Math.round(annualTax / 12);

    const net = gross - siAmount - hfAmount - monthlyTax;

    netPayEl.textContent = net.toLocaleString() + ' 元';
    siAmtEl.textContent = siAmount.toLocaleString() + ' 元';
    hfAmtEl.textContent = hfAmount.toLocaleString() + ' 元';
    taxableEl.textContent = (monthlyTaxable > 0 ? monthlyTaxable.toLocaleString() : '0') + ' 元';
    taxEl.textContent = monthlyTax.toLocaleString() + ' 元';
  }

  grossInput.addEventListener('input', recalc);
  citySelect.addEventListener('change', recalc);
  fundSelect.addEventListener('change', recalc);
  dedInput.addEventListener('input', recalc);
  customBaseInput.addEventListener('input', recalc);

  recalc();
</script>

