  .pfc-tooltip-content {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    padding: 1.5rem;
    max-width: 400px;
    width: 90%;
    box-shadow: 0 8px 32px rgba(0,0,0,0.15);
  }

  .pfc-tooltip-content strong {
    display: block;
    font-size: 1rem;
    margin-bottom: 0.75rem;
