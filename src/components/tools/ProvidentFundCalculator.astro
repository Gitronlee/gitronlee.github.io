    vertical-align: middle;
  }

  /* ---- Cell Widths ---- */
  .pfc-col-seq { width: 48px; }
  .pfc-col-month { width: 130px; }
  .pfc-col-actual { width: 130px; }
  .pfc-col-legal { width: 130px; }
  .pfc-col-company { width: 80px; }
  .pfc-col-personal { width: 80px; }
  .pfc-col-diff { width: 100px; }
  .pfc-col-action { width: 56px; }

  /* ---- Table Inputs ---- */
  .pfc-input {
    width: 100%;
    height: 36px;
    padding: 0 0.5rem;
    border: 1px solid #d1d9e6;
    border-radius: 6px;
    font-size: 0.875rem;
    font-family: 'JetBrains Mono', monospace;
    background: var(--bg-primary);
    color: var(--text-primary);
    text-align: center;
    transition: var(--transition);
  }

  .pfc-input:focus {
    border-color: #3498db;
    outline: none;
    box-shadow: 0 0 0 3px rgba(52, 152, 219, 0.15);
