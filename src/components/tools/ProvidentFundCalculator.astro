    padding: 0.625rem;
    background: #3498db;
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 0.875rem;
    font-family: inherit;
    cursor: pointer;
    transition: var(--transition);
  }

  .pfc-tooltip-close:hover {
    background: #2980b9;
  }

  /* ---- Toast ---- */
  .pfc-toast {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    background: #2c3e50;
    color: #fff;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-size: 0.875rem;
