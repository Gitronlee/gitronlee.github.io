<div class="pfc-root" id="pfcRoot">
  <!-- Data Table -->
  <div class="pfc-table-wrap">
    <table class="pfc-table" id="dataTable">
      <thead>
        <tr>
          <th class="pfc-col-seq">序号</th>
          <th class="pfc-col-month">月份</th>
          <th class="pfc-col-actual">实际申报基数<br/><span class="th-unit">(元)</span></th>
          <th class="pfc-col-legal">
            法定应缴基数<br/><span class="th-unit">(元)</span>
            <span class="th-hint" id="smartFillHint" title="建议填写上年度1-12月税前总收入 ÷ 12">⚡</span>
          </th>
          <th class="pfc-col-company">单位比例<br/><span class="th-unit">(%)</span></th>
          <th class="pfc-col-personal">个人比例<br/><span class="th-unit">(%)</span></th>
          <th class="pfc-col-diff">本行差额<br/><span class="th-unit">(元)</span></th>
          <th class="pfc-col-action">操作</th>
        </tr>
      </thead>
      <tbody id="tableBody">
        <!-- Rows rendered by JS -->
      </tbody>
    </table>
  </div>

  <!-- Add Row Button -->
  <button class="pfc-add-btn" id="addRowBtn">＋ 追加一行</button>

  <!-- Action Buttons -->
  <div class="pfc-actions-row">
    <button class="pfc-btn pfc-btn-recalc" id="recalcAllBtn">🔄 重算所有行</button>
    <button class="pfc-btn pfc-btn-reset" id="resetAllBtn">🗑 清空所有数据</button>
  </div>

  <!-- Summary -->
  <div class="pfc-summary" id="summarySection">
    <div class="pfc-summary-grid">
      <div class="pfc-summary-item">
        <span class="pfc-summary-label">补缴总月数</span>
        <span class="pfc-summary-value" id="totalMonths">0</span>
      </div>
      <div class="pfc-summary-item">
        <span class="pfc-summary-label">单位应补总额</span>
        <span class="pfc-summary-value" id="totalCompanyDiff">0.00</span>
      </div>
      <div class="pfc-summary-item">
        <span class="pfc-summary-label">个人应补总额</span>
        <span class="pfc-summary-value" id="totalPersonalDiff">0.00</span>
      </div>
      <div class="pfc-summary-item pfc-summary-total">
        <span class="pfc-summary-label">合计补缴总额</span>
        <span class="pfc-summary-value pfc-total-highlight" id="grandTotal">0.00</span>
      </div>
    </div>
    <button class="pfc-btn pfc-btn-copy" id="copySummaryBtn">📋 一键复制结果摘要</button>
  </div>

  <!-- Smart Fill Tooltip -->
  <div class="pfc-tooltip" id="smartFillTooltip" style="display:none">
    <div class="pfc-tooltip-content">
      <strong>💡 智能填写提示</strong>
      <p>建议填写<strong>上年度1-12月税前总收入 ÷ 12</strong></p>
      <p class="pfc-tooltip-example">例：上年度总收入 180,000 元 → 法定基数 = 15,000 元</p>
      <button class="pfc-tooltip-close" id="tooltipClose">知道了</button>
    </div>
  </div>

  <!-- Toast -->
  <div class="pfc-toast" id="toast" style="display:none"></div>
</div>

<script>
(function() {
  'use strict';

  // ---- Constants ----
  const STORAGE_KEY = 'provident_fund_data';
  const CITY_MIN = 0;
  const CITY_MAX = 30000;

  // ---- State ----
  interface RowData {
    id: string;
    month: string;
    actualBase: string;
    legalBase: string;
    companyRate: string;
    personalRate: string;
  }

  let rows: RowData[] = [];
  let seqCounter = 0;

  // ---- DOM refs ----
  const tableBody = document.getElementById('tableBody')!;
  const addRowBtn = document.getElementById('addRowBtn')!;
  const recalcAllBtn = document.getElementById('recalcAllBtn')!;
  const resetAllBtn = document.getElementById('resetAllBtn')!;
  const copySummaryBtn = document.getElementById('copySummaryBtn')!;
  const smartFillHint = document.getElementById('smartFillHint')!;
  const smartFillTooltip = document.getElementById('smartFillTooltip')!;
  const tooltipClose = document.getElementById('tooltipClose')!;
  const toast = document.getElementById('toast')!;
  const totalMonthsEl = document.getElementById('totalMonths')!;
  const totalCompanyDiffEl = document.getElementById('totalCompanyDiff')!;
  const totalPersonalDiffEl = document.getElementById('totalPersonalDiff')!;
  const grandTotalEl = document.getElementById('grandTotal')!;

  // ---- Utility ----
  function round2(n: number): string {
    return (Math.round(n * 100) / 100).toFixed(2);
  }

  function clamp(val: number, min: number, max: number): number {
    return Math.min(Math.max(val, min), max);
  }

  function getCurrentMonth(): string {
    const d = new Date();
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    return `${y}-${m}`;
  }

  function addOneMonth(monthStr: string): string {
    const [y, m] = monthStr.split('-').map(Number);
    const d = new Date(y, m - 1 + 1, 1);
    const ny = d.getFullYear();
    const nm = String(d.getMonth() + 1).padStart(2, '0');
    return `${ny}-${nm}`;
  }

  function showToast(msg: string, duration = 2000) {
    toast.textContent = msg;
    toast.style.display = 'block';
    setTimeout(() => { toast.style.display = 'none'; }, duration);
  }

  // ---- Calculation ----
  function calcRowDiff(row: RowData): { companyDiff: number; personalDiff: number; total: number } | null {
    const actual = parseFloat(row.actualBase);
    const legal = parseFloat(row.legalBase);
    const compRate = parseFloat(row.companyRate);
    const persRate = parseFloat(row.personalRate);

    if (isNaN(actual) || isNaN(legal) || isNaN(compRate) || isNaN(persRate)) {
      return null;
    }

    // Apply clamp (MEDIAN = clamp to [min, max])
    const clampedLegal = clamp(legal, CITY_MIN, CITY_MAX);
    const clampedActual = clamp(actual, CITY_MIN, CITY_MAX);

    const shouldCompany = clampedLegal * (compRate / 100);
    const actualCompany = clampedActual * (compRate / 100);
    const shouldPersonal = clampedLegal * (persRate / 100);
    const actualPersonal = clampedActual * (persRate / 100);

    const companyDiff = Math.round((shouldCompany - actualCompany) * 100) / 100;
    const personalDiff = Math.round((shouldPersonal - actualPersonal) * 100) / 100;

    return {
      companyDiff,
      personalDiff,
      total: Math.round((companyDiff + personalDiff) * 100) / 100,
    };
  }

  // ---- Render ----
  function renderTable() {
    tableBody.innerHTML = '';
    rows.forEach((row, idx) => {
      const diff = calcRowDiff(row);
      const diffDisplay = diff ? round2(diff.total) : '——';
      const diffClass = diff && diff.total > 0 ? 'pfc-diff-positive' : (diff && diff.total < 0 ? 'pfc-diff-negative' : '');

      const tr = document.createElement('tr');
      tr.dataset.id = row.id;
      tr.innerHTML = `
        <td class="pfc-cell-seq">${idx + 1}</td>
        <td><input type="month" class="pfc-input pfc-input-month" value="${row.month}" data-field="month" /></td>
        <td><input type="number" class="pfc-input" value="${row.actualBase}" placeholder="0" data-field="actualBase" min="0" step="100" /></td>
        <td>
          <div class="pfc-legal-cell">
            <input type="number" class="pfc-input" value="${row.legalBase}" placeholder="0" data-field="legalBase" min="0" step="100" />
          </div>
        </td>
        <td><input type="number" class="pfc-input pfc-input-rate" value="${row.companyRate}" data-field="companyRate" min="1" max="12" step="1" /></td>
        <td><input type="number" class="pfc-input pfc-input-rate" value="${row.personalRate}" data-field="personalRate" min="1" max="12" step="1" /></td>
        <td class="pfc-cell-diff ${diffClass}">${diffDisplay}</td>
        <td><button class="pfc-btn-delete" title="删除此行">✕</button></td>
      `;
      tableBody.appendChild(tr);
    });

    updateSummary();
  }

  function updateSummary() {
    let totalCompany = 0;
    let totalPersonal = 0;
    let validMonths = 0;

    rows.forEach(row => {
      const diff = calcRowDiff(row);
      if (diff) {
        totalCompany += diff.companyDiff;
        totalPersonal += diff.personalDiff;
        validMonths++;
      }
    });

    totalCompany = Math.round(totalCompany * 100) / 100;
    totalPersonal = Math.round(totalPersonal * 100) / 100;
    const grand = Math.round((totalCompany + totalPersonal) * 100) / 100;

    totalMonthsEl.textContent = String(validMonths);
    totalCompanyDiffEl.textContent = round2(totalCompany);
    totalPersonalDiffEl.textContent = round2(totalPersonal);
    grandTotalEl.textContent = round2(grand);
  }

  // ---- Persistence ----
  function saveData() {
    const data = { rows };
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
    } catch (e) {
      // ignore
    }
  }

  function loadData() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return false;
      const data = JSON.parse(raw);
      if (Array.isArray(data.rows)) {
        rows = data.rows;
        return true;
      }
    } catch (e) {
      // ignore
    }
    return false;
  }

  // ---- Row Operations ----
  function createRow(prevRow?: RowData): RowData {
    const newMonth = prevRow ? addOneMonth(prevRow.month) : getCurrentMonth();
    return {
      id: 'row_' + Date.now() + '_' + (seqCounter++),
      month: newMonth,
      actualBase: '',
      legalBase: prevRow ? prevRow.legalBase : '',
      companyRate: prevRow ? prevRow.companyRate : '5',
      personalRate: prevRow ? prevRow.personalRate : '5',
    };
  }

  function addRow() {
    const lastRow = rows.length > 0 ? rows[rows.length - 1] : undefined;
    const newRow = createRow(lastRow);
    rows.push(newRow);
    renderTable();
    saveData();
    const lastTr = tableBody.lastElementChild;
    if (lastTr) lastTr.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function deleteRow(id: string) {
    rows = rows.filter(r => r.id !== id);
    renderTable();
    saveData();
  }

  // ---- Event Delegation on Table ----
  tableBody.addEventListener('input', (e) => {
    const target = e.target as HTMLInputElement;
    if (!target.matches('.pfc-input')) return;
    const tr = target.closest('tr');
    if (!tr) return;
    const id = (tr as HTMLElement).dataset.id;
    const field = target.dataset.field;
    if (!id || !field) return;

    const row = rows.find(r => r.id === id);
    if (row) {
      (row as any)[field] = target.value;
      saveData();
      const diff = calcRowDiff(row);
      const diffCell = tr.querySelector('.pfc-cell-diff');
      if (diffCell) {
        diffCell.textContent = diff ? round2(diff.total) : '——';
        diffCell.className = 'pfc-cell-diff' + (diff && diff.total > 0 ? ' pfc-diff-positive' : (diff && diff.total < 0 ? ' pfc-diff-negative' : ''));
      }
      updateSummary();
    }
  });

  tableBody.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.classList.contains('pfc-btn-delete')) {
      const tr = target.closest('tr');
      if (tr) {
        const id = (tr as HTMLElement).dataset.id;
        if (id) deleteRow(id);
      }
    }
  });

  // ---- Add Row ----
  addRowBtn.addEventListener('click', addRow);

  // ---- Recalc All ----
  recalcAllBtn.addEventListener('click', () => {
    renderTable();
    saveData();
    showToast('已重算所有行');
  });

  // ---- Reset All ----
  resetAllBtn.addEventListener('click', () => {
    if (confirm('确定要清空所有数据吗？此操作不可撤销。')) {
      rows = [];
      renderTable();
      saveData();
      showToast('已清空所有数据');
    }
  });

  // ---- Smart Fill Hint ----
  smartFillHint.addEventListener('click', (e) => {
    e.stopPropagation();
    smartFillTooltip.style.display = smartFillTooltip.style.display === 'none' ? 'block' : 'none';
  });
  tooltipClose.addEventListener('click', () => {
    smartFillTooltip.style.display = 'none';
  });
  document.addEventListener('click', (e) => {
    if (!smartFillTooltip.contains(e.target as Node) && e.target !== smartFillHint) {
      smartFillTooltip.style.display = 'none';
    }
  });

  // ---- Copy Summary ----
  copySummaryBtn.addEventListener('click', () => {
    const lines: string[] = [];
    lines.push('公积金差额补缴计算结果摘要');
    lines.push('================================');
    lines.push(`城市下限: ${CITY_MIN.toLocaleString()} 元 | 城市上限: ${CITY_MAX.toLocaleString()} 元`);
    lines.push('');

    let totalCompany = 0;
    let totalPersonal = 0;
    let validMonths = 0;

    rows.forEach((row, idx) => {
      const diff = calcRowDiff(row);
      if (diff) {
        totalCompany += diff.companyDiff;
        totalPersonal += diff.personalDiff;
        validMonths++;
        lines.push(`${row.month} | 实际基数: ${row.actualBase || '0'} | 法定基数: ${row.legalBase || '0'} | 单位${row.companyRate}%+个人${row.personalRate}% | 差额: ${round2(diff.total)} 元`);
      }
    });

    totalCompany = Math.round(totalCompany * 100) / 100;
    totalPersonal = Math.round(totalPersonal * 100) / 100;
    const grand = Math.round((totalCompany + totalPersonal) * 100) / 100;

    lines.push('');
    lines.push('================================');
    lines.push(`补缴总月数: ${validMonths}`);
    lines.push(`单位应补总额: ${round2(totalCompany)} 元`);
    lines.push(`个人应补总额: ${round2(totalPersonal)} 元`);
    lines.push(`合计补缴总额: ${round2(grand)} 元`);

    navigator.clipboard.writeText(lines.join('\n')).then(() => {
      showToast('✅ 已复制到剪贴板');
    }).catch(() => {
      showToast('❌ 复制失败，请手动复制');
    });
  });

  // ---- Init ----
  const loaded = loadData();
  if (!loaded) {
    rows.push(createRow());
  }
  renderTable();
})();
</script>

<style>
  .pfc-root {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: relative;
  }

  /* ---- Buttons ---- */
  .pfc-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    border: 1px solid var(--border-color);
    border-radius: 6px;
    font-size: 0.875rem;
    font-family: inherit;
    cursor: pointer;
    transition: var(--transition);
    background: var(--bg-primary);
    color: var(--text-primary);
  }

  .pfc-btn:hover {
    background: var(--border-color);
  }

  .pfc-btn-reset {
    color: #e74c3c;
    border-color: #e74c3c;
  }

  .pfc-btn-reset:hover {
    background: rgba(231, 76, 60, 0.1);
  }

  .pfc-btn-recalc {
    background: #3498db;
    color: #fff;
    border-color: #3498db;
  }

  .pfc-btn-recalc:hover {
    background: #2980b9;
  }

  .pfc-btn-copy {
    background: #3498db;
    color: #fff;
    border-color: #3498db;
    font-weight: 600;
  }

  .pfc-btn-copy:hover {
    background: #2980b9;
  }

  /* ---- Table ---- */
  .pfc-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
  }

  .pfc-table {
    width: 100%;
    min-width: 780px;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .pfc-table thead {
    background: #2c3e50;
    color: #fff;
  }

  .pfc-table th {
    padding: 0.75rem 0.625rem;
