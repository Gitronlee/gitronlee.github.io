  }

  .pfc-summary-total {
    background: #e74c3c;
  }

  .pfc-summary-total .pfc-summary-label {
    color: rgba(255,255,255,0.85);
  }

  .pfc-total-highlight {
    color: #fff !important;
    font-size: 1.5rem !important;
  }

  .pfc-summary .pfc-btn-copy {
    width: 100%;
    justify-content: center;
    padding: 0.75rem;
  }

  /* ---- Tooltip ---- */
  .pfc-tooltip {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
