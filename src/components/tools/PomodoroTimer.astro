<div class="pomodoro-timer" id="pomodoroRoot">
  <div class="timer-display">
    <svg class="timer-ring" viewBox="0 0 200 200">
      <circle class="ring-bg" cx="100" cy="100" r="85" />
      <circle class="ring-progress" cx="100" cy="100" r="85" id="timerRing" />
    </svg>
    <div class="timer-center">
      <span class="timer-time" id="timerTime">25:00</span>
      <span class="timer-label" id="timerLabel">工作时间</span>
    </div>
  </div>

  <div class="timer-controls">
    <button class="btn-timer btn-start" id="btnStart">开始</button>
    <button class="btn-timer btn-pause" id="btnPause" style="display:none">暂停</button>
    <button class="btn-timer btn-reset" id="btnReset">重置</button>
  </div>

  <div class="timer-presets">
    <button class="preset active" data-work="25" data-break="5">25 分钟</button>
    <button class="preset" data-work="45" data-break="10">45 分钟</button>
    <button class="preset" data-work="15" data-break="3">15 分钟</button>
  </div>

  <div class="timer-stats">
    <div class="stat-item">
      <span class="stat-value" id="sessionCount">0</span>
      <span class="stat-label">完成轮次</span>
    </div>
    <div class="stat-item">
      <span class="stat-value" id="totalFocus">0</span>
      <span class="stat-label">总专注(分钟)</span>
    </div>
  </div>
</div>

<script>
  const root = document.getElementById('pomodoroRoot')!;
  const timerTime = document.getElementById('timerTime')!;
  const timerLabel = document.getElementById('timerLabel')!;
  const timerRing = document.getElementById('timerRing')!;
  const btnStart = document.getElementById('btnStart')!;
  const btnPause = document.getElementById('btnPause')!;
  const btnReset = document.getElementById('btnReset')!;
  const sessionCount = document.getElementById('sessionCount')!;
  const totalFocus = document.getElementById('totalFocus')!;

  const ringLength = 2 * Math.PI * 85;
  timerRing.setAttribute('stroke-dasharray', String(ringLength));
  timerRing.setAttribute('stroke-dashoffset', '0');

  let workDuration = 25 * 60;
  let breakDuration = 5 * 60;
  let timeLeft = workDuration;
  let isRunning = false;
  let isWorkSession = true;
  let intervalId: ReturnType<typeof setInterval> | null = null;
  let sessions = 0;
  let totalMinutes = 0;
  let endTime = 0;

  const audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();

  function playBeep() {
    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();
    osc.connect(gain);
    gain.connect(audioCtx.destination);
    osc.frequency.value = 880;
    osc.type = 'sine';
    gain.gain.value = 0.3;
    osc.start();
    gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.3);
    osc.stop(audioCtx.currentTime + 0.3);
  }

  function formatTime(seconds: number): string {
    const m = Math.floor(seconds / 60);
    const s = seconds % 60;
    return `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
  }

  function updateDisplay() {
    timerTime.textContent = formatTime(timeLeft);
    timerLabel.textContent = isWorkSession ? '工作时间' : '休息时间';

    const total = isWorkSession ? workDuration : breakDuration;
    const progress = (total - timeLeft) / total;
    timerRing.setAttribute('stroke-dashoffset', String(ringLength * progress));
  }

  function switchSession() {
    if (isWorkSession) {
      sessions++;
      totalMinutes += workDuration / 60;
      sessionCount.textContent = String(sessions);
      totalFocus.textContent = String(Math.round(totalMinutes));
    }

    isWorkSession = !isWorkSession;
    timeLeft = isWorkSession ? workDuration : breakDuration;
    endTime = Date.now() + timeLeft * 1000;
    updateDisplay();

    playBeep();
    setTimeout(() => playBeep(), 400);
    setTimeout(() => playBeep(), 800);
  }

  function tick() {
    const remaining = Math.max(0, Math.ceil((endTime - Date.now()) / 1000));
    timeLeft = remaining;
    updateDisplay();
    if (timeLeft <= 0) {
      switchSession();
    }
  }

  function startTimer() {
    if (isRunning) return;
    isRunning = true;
    btnStart.style.display = 'none';
    btnPause.style.display = '';
    document.querySelectorAll('.preset').forEach(b => (b as HTMLButtonElement).disabled = true);
    audioCtx.resume();
    endTime = Date.now() + timeLeft * 1000;
    intervalId = setInterval(tick, 200);
  }

  function pauseTimer() {
    if (!isRunning) return;
    isRunning = false;
    btnStart.style.display = '';
    btnPause.style.display = 'none';
    document.querySelectorAll('.preset').forEach(b => (b as HTMLButtonElement).disabled = false);
    if (intervalId) { clearInterval(intervalId); intervalId = null; }
  }

  function resetTimer() {
    pauseTimer();
    timeLeft = workDuration;
    isWorkSession = true;
    updateDisplay();
  }

  btnStart.addEventListener('click', startTimer);
  btnPause.addEventListener('click', pauseTimer);
  btnReset.addEventListener('click', resetTimer);

  root.querySelectorAll('.preset').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLButtonElement;
      if (isRunning) return;
      root.querySelectorAll('.preset').forEach(b => b.classList.remove('active'));
      el.classList.add('active');
      workDuration = parseInt(el.dataset.work!) * 60;
      breakDuration = parseInt(el.dataset.break!) * 60;
      resetTimer();
    });
  });

  updateDisplay();
</script>

<style>
