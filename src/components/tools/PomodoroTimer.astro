  }

  .timer-time {
    font-family: 'JetBrains Mono', monospace;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .timer-label {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-top: 0.25rem;
  }

  .timer-controls {
    display: flex;
    gap: 0.75rem;
  }

  .btn-timer {
    padding: 0.6rem 2rem;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: var(--transition);
  }

  .btn-start {
    background: var(--accent-green);
    color: #000;
  }

  .btn-start:hover {
    background: #00e676;
  }

  .btn-pause {
    background: var(--accent-orange);
