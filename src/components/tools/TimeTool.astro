  }
  
  .current-time {
    background: var(--bg-primary);
    padding: 1rem;
    border-radius: 8px;
    border: 1px solid var(--accent-cyan);
  }
  
  .time-display {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  
  .timestamp {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.5rem;
    color: var(--accent-cyan);
    font-weight: 700;
  }
  
  .date {
    color: var(--text-primary);
  }
  
  .section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .convert-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  
  .convert-row input {
    flex: 1;
    min-width: 200px;
  }
  
  input, input[type="text"], input[type="datetime-local"] {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    padding: 0.75rem;
    border-radius: 8px;
    font-family: 'JetBrains Mono', monospace;
  }
  
  input:focus {
    border-color: var(--accent-blue);
    outline: none;
  }
  
  .arrow {
    color: var(--accent-purple);
    font-size: 1.5rem;
  }
  
  .result {
    color: var(--text-primary);
    font-family: 'JetBrains Mono', monospace;
  }
  
  .result-row {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
