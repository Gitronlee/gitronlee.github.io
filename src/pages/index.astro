---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CardGrid from '../components/CardGrid.astro';
import tools from '../data/tools.json';
import games from '../data/games.json';

const featuredTools = tools.slice(0, 6).map((tool) => ({
  ...tool,
  href: `/tools/${tool.slug}`,
}));

const gamesItems = games.map((game) => ({
  ...game,
  href: `/games/${game.slug}`,
}));
---

<BaseLayout title="Tooli - 百宝箱" description="各种实用开发者工具、小游戏和学习文档集合">
  <Header />
  
  <main>
    <section class="hero">
      <div class="container">
        <h1 class="hero-title">Tooli</h1>
        <p class="hero-desc">实用开发者工具 · 休闲小游戏 · 技巧学习文档</p>
        <div class="hero-stats">
          <span class="stat">{tools.length}+ 工具</span>
          <span class="stat">{games.length}+ 游戏</span>
          <span class="stat">持续更新</span>
        </div>
      </div>
    </section>
    
    <section class="container section">
      <div class="section-header">
        <h2 class="section-title">热门工具</h2>
        <a href="/tools" class="view-all">查看全部 →</a>
      </div>
      <CardGrid items={featuredTools} />
    </section>
    
    <section class="container section">
      <div class="section-header">
        <h2 class="section-title">小游戏</h2>
        <a href="/games" class="view-all">查看全部 →</a>
      </div>
      <CardGrid items={gamesItems} />
    </section>
  </main>
  
  <Footer />
</BaseLayout>

<style>
  .hero {
    background: var(--bg-secondary);
    padding: 5rem 0 4rem;
    text-align: center;
    border-bottom: 1px solid var(--border-color);
  }
  
  .hero-title {
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
  }
  
  .hero-desc {
    font-size: 1.125rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }
  
  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
  }
  
  .stat {
    background: var(--bg-tertiary);
    padding: 0.5rem 1.25rem;
    border-radius: 20px;
    font-size: 0.875rem;
    color: var(--text-secondary);
  }
  
  .section {
    padding-top: 3rem;
    padding-bottom: 3rem;
  }
  
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }
  
  .section-title {
    font-size: 1.5rem;
    font-weight: 600;
  }
  
  .view-all {
    color: var(--text-muted);
    font-size: 0.875rem;
    font-weight: 500;
  }
  
  .view-all:hover {
    color: var(--accent-blue);
  }
</style>
