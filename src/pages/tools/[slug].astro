---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ToolLayout from '../../components/ToolLayout.astro';
import tools from '../../data/tools.json';

export function getStaticPaths() {
  return tools.map((tool) => ({
    params: { slug: tool.slug },
    props: tool,
  }));
}

const toolMap: Record<string, any> = {
  'regex': (await import('../../components/tools/RegexTool.astro')).default,
  'time': (await import('../../components/tools/TimeTool.astro')).default,
  'base64': (await import('../../components/tools/Base64Tool.astro')).default,
  'json': (await import('../../components/tools/JsonTool.astro')).default,
  'url': (await import('../../components/tools/UrlTool.astro')).default,
  'hash': (await import('../../components/tools/HashTool.astro')).default,
  'color': (await import('../../components/tools/ColorTool.astro')).default,
  'pomodoro': (await import('../../components/tools/PomodoroTimer.astro')).default,
  'salary': (await import('../../components/tools/SalaryCalculator.astro')).default,
  'image-slicer': (await import('../../components/tools/ImageSlicer.astro')).default,
  'life-timer': (await import('../../components/tools/LifeTimer.astro')).default,
};

const { slug } = Astro.params;
const tool = Astro.props;
const ToolComponent = toolMap[slug!];

if (!tool || !ToolComponent) {
  return Astro.redirect('/404');
}
---

<BaseLayout title={tool.name} description={tool.description}>
  <Header />
  
  <main>
    <ToolLayout title={tool.name} description={tool.description}>
      <ToolComponent />
    </ToolLayout>
  </main>
  
  <Footer />
</BaseLayout>
